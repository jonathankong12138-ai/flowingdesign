{%- comment -%}
  Four-Column Parallel Text Box - 四栏并列文本框组件
  特点：Urbanist 字体, 独立控制每栏字号/字重/对齐, 宽度 auto-width
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- liquid
  assign section_id = section.id | replace: '_', '' | downcase
-%}

{%- style -%}
  .flowing-typography-{{ section_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: 'Urbanist', sans-serif;
  }

  .quad-text-container-{{ section_id }} {
    display: flex;
    flex-wrap: nowrap;
    gap: {{ section.settings.gap }}px;
    width: 100%;
    align-items: {{ section.settings.vertical_align }};
    justify-content: {{ section.settings.horizontal_justify }};
  }

  .quad-text-column-{{ section_id }} {
    flex: 0 0 auto;
    min-width: 0;
  }

  /* 循环生成四栏样式，使用 assign 避免空格 bug */
  {%- for i in (1..4) -%}
    {%- assign s_size = 'size_' | append: i -%}
    {%- assign s_weight = 'weight_' | append: i -%}
    {%- assign s_lh = 'lh_' | append: i -%}
    {%- assign s_align = 'align_' | append: i -%}
    {%- assign s_color = 'color_' | append: i -%}
    
    .quad-text-item-{{ i }}-{{ section_id }} {
      font-size: {{ section.settings[s_size] }}px;
      font-weight: {{ section.settings[s_weight] }};
      line-height: {{ section.settings[s_lh] }};
      text-align: {{ section.settings[s_align] }};
      color: {{ section.settings[s_color] }};
      word-wrap: break-word;
      overflow-wrap: break-word;
      letter-spacing: -0.02em;
    }
  {%- endfor -%}

  @media screen and (max-width: 767px) {
    .quad-text-container-{{ section_id }} {
      flex-direction: {{ section.settings.mobile_layout }};
      {%- if section.settings.mobile_layout == 'column' -%}
        align-items: flex-start;
      {%- endif -%}
    }
    .quad-text-column-{{ section_id }} {
      width: {% if section.settings.mobile_layout == 'column' %}100%{% else %}auto{% endif %};
    }
    {%- for i in (1..4) -%}
      {%- assign s_size = 'size_' | append: i -%}
      .quad-text-item-{{ i }}-{{ section_id }} {
        font-size: clamp(14px, {{ section.settings[s_size] | times: 0.7 }}px, 40px);
      }
    {%- endfor -%}
  }
{%- endstyle -%}

<div class="flowing-typography-{{ section_id }}">
  <div class="quad-text-container-{{ section_id }}">
    {%- for i in (1..4) -%}
      {%- assign s_text = 'text_' | append: i -%}
      {%- if section.settings[s_text] != blank -%}
        <div class="quad-text-column-{{ section_id }}">
          <div class="quad-text-item-{{ i }}-{{ section_id }}">
            {{ section.settings[s_text] | newline_to_br }}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "四栏并列文本",
  "settings": [
    {
      "type": "header",
      "content": "第一栏"
    },
    { "type": "textarea", "id": "text_1", "label": "文本内容", "default": "Flowing" },
    { "type": "range", "id": "size_1", "label": "字号", "min": 10, "max": 150, "step": 2, "unit": "px", "default": 72 },
    { "type": "select", "id": "weight_1", "label": "字重", "options": [
        { "value": "200", "label": "Extralight" },
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semibold" }
      ], "default": "200" },
    { "type": "range", "id": "lh_1", "label": "行高", "min": 0.8, "max": 2.0, "step": 0.1, "default": 1.1 },
    { "type": "select", "id": "align_1", "label": "对齐", "options": [
        { "value": "left", "label": "左" }, { "value": "center", "label": "中" }, { "value": "right", "label": "右" }
      ], "default": "left" },
    { "type": "color", "id": "color_1", "label": "颜色", "default": "#1a1a1a" },

    {
      "type": "header",
      "content": "第二栏"
    },
    { "type": "textarea", "id": "text_2", "label": "文本内容", "default": "Vision" },
    { "type": "range", "id": "size_2", "label": "字号", "min": 10, "max": 150, "step": 2, "unit": "px", "default": 32 },
    { "type": "select", "id": "weight_2", "label": "字重", "options": [
        { "value": "200", "label": "Extralight" },
        { "value": "400", "label": "Normal" }
      ], "default": "200" },
    { "type": "range", "id": "lh_2", "label": "行高", "min": 0.8, "max": 2.0, "step": 0.1, "default": 1.1 },
    { "type": "select", "id": "align_2", "label": "对齐", "options": [
        { "value": "left", "label": "左" }, { "value": "center", "label": "中" }
      ], "default": "left" },
    { "type": "color", "id": "color_2", "label": "颜色", "default": "#1a1a1a" },

    {
      "type": "header",
      "content": "第三栏"
    },
    { "type": "textarea", "id": "text_3", "label": "文本内容", "default": "Stream" },
    { "type": "range", "id": "size_3", "label": "字号", "min": 10, "max": 150, "step": 2, "unit": "px", "default": 72 },
    { "type": "select", "id": "weight_3", "label": "字重", "options": [
        { "value": "200", "label": "Extralight" },
        { "value": "400", "label": "Normal" }
      ], "default": "200" },
    { "type": "range", "id": "lh_3", "label": "行高", "min": 0.8, "max": 2.0, "step": 0.1, "default": 1.1 },
    { "type": "select", "id": "align_3", "label": "对齐", "options": [
        { "value": "left", "label": "左" }, { "value": "center", "label": "中" }
      ], "default": "left" },
    { "type": "color", "id": "color_3", "label": "颜色", "default": "#1a1a1a" },

    {
      "type": "header",
      "content": "第四栏"
    },
    { "type": "textarea", "id": "text_4", "label": "文本内容", "default": "Insight" },
    { "type": "range", "id": "size_4", "label": "字号", "min": 10, "max": 150, "step": 2, "unit": "px", "default": 32 },
    { "type": "select", "id": "weight_4", "label": "字重", "options": [
        { "value": "200", "label": "Extralight" },
        { "value": "400", "label": "Normal" }
      ], "default": "200" },
    { "type": "range", "id": "lh_4", "label": "行高", "min": 0.8, "max": 2.0, "step": 0.1, "default": 1.1 },
    { "type": "select", "id": "align_4", "label": "对齐", "options": [
        { "value": "left", "label": "左" }, { "value": "center", "label": "中" }
      ], "default": "left" },
    { "type": "color", "id": "color_4", "label": "颜色", "default": "#1a1a1a" },

    {
      "type": "header",
      "content": "全局布局"
    },
    { "type": "select", "id": "horizontal_justify", "label": "横向排列", "options": [
        { "value": "flex-start", "label": "左对齐" },
        { "value": "center", "label": "居中" },
        { "value": "space-between", "label": "两端对齐" }
      ], "default": "flex-start" },
    { "type": "select", "id": "vertical_align", "label": "垂直对齐", "options": [
        { "value": "flex-start", "label": "顶部" },
        { "value": "center", "label": "居中" },
        { "value": "flex-end", "label": "底部" }
      ], "default": "center" },
    { "type": "range", "id": "gap", "label": "列间距", "min": 0, "max": 100, "step": 5, "unit": "px", "default": 20 },
    { "type": "range", "id": "desktop_width_percent", "label": "桌面端容器宽度", "min": 50, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "select", "id": "mobile_layout", "label": "移动端布局", "options": [
        { "value": "column", "label": "垂直堆叠" },
        { "value": "row", "label": "保持并列" }
      ], "default": "column" },
    { "type": "range", "id": "padding_top", "label": "顶部间距", "min": 0, "max": 200, "step": 10, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "底部间距", "min": 0, "max": 200, "step": 10, "unit": "px", "default": 80 }
  ],
  "presets": [
    {
      "name": "流动四栏文本"
    }
  ]
}
{% endschema %}