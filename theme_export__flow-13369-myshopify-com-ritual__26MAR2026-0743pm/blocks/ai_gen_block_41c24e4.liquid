{%- comment -%}
  更新：
  1. 适配逻辑调整：手机端和桌面端在宽度不足时均采用文字自然换行，不再使用 JS 强行缩放。
  2. 手机端字体：先执行后台设置的缩放比例，不足时再换行。
  3. 结构零改变：维持平铺循环结构，保持阶梯布局。
  4. 视觉保留：保留 Blend Mode 穿透、右侧无空白、抗抖动占位符。
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- liquid
  assign block_id = block.id | replace: '_', '' | downcase
  assign opacity_decimal = block.settings.background_opacity | divided_by: 100.0
  assign bg_color_rgba = block.settings.background_color | color_modify: 'alpha', opacity_decimal
  assign mobile_scale = block.settings.mobile_font_scale | divided_by: 100.0
-%}

{%- style -%}
  /* 允许 blend-mode 穿透到背景层 */
  .glacier-content-{{ section.id }} {
    z-index: auto !important;
    isolation: auto !important;
  }

  /* 干掉 Shopify 干扰 */
  #shopify-section-{{ section.id }} .shopify-block {
    margin: 0 !important;
    padding: 0 !important;
  }

  .ai-text-wrapper-{{ block_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    position: relative;
    isolation: auto !important;
    {% if block.settings.horizontal_justify == 'flex-start' %}
      margin: 0 auto 0 0 !important;
    {% elsif block.settings.horizontal_justify == 'flex-end' %}
      margin: 0 0 0 auto !important;
    {% else %}
      margin: 0 auto !important; 
    {% endif %}
    padding: 0 !important;
    font-family: 'Urbanist', sans-serif;
  }

  .ai-text-container-{{ block_id }} {
    display: flex;
    flex-direction: {{ block.settings.desktop_layout }};
    flex-wrap: wrap; /* 允许换行 */
    gap: {{ block.settings.gap }}px;
    width: {% if block.settings.container_width_mode == 'fit' %}fit-content{% else %}100%{% endif %};
    isolation: auto !important;
    {% if block.settings.desktop_layout == 'column' %}
      align-items: {{ block.settings.horizontal_justify | replace: 'space-between', 'flex-start' }};
      justify-content: {{ block.settings.vertical_align }};
    {% else %}
      align-items: {{ block.settings.vertical_align }};
      justify-content: {{ block.settings.horizontal_justify }};
    {% endif %}
  }

  .ai-column-{{ block_id }} {
    min-width: 0;
    padding: {{ block.settings.box_padding }}px;
    background-color: {{ bg_color_rgba }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.3s ease;
    box-sizing: border-box;
    cursor: pointer;
    flex: 0 0 auto;
    isolation: auto !important;
    max-width: 100%; /* 防止单个文本块溢出 */
  }

  .ai-item-wrapper-{{ block_id }} {
    display: grid;
    width: fit-content; /* 确保紧凑 */
    max-width: 100%;
    align-items: center;
    justify-items: start;
    isolation: auto !important;
    white-space: normal !important; /* 允许文字换行 */
    word-break: break-word;
  }

  {%- for i in (1..4) -%}
    {%- assign s_size = 'size_' | append: i -%}
    {%- assign s_weight = 'weight_' | append: i -%}
    {%- assign s_lh = 'lh_' | append: i -%}
    {%- assign s_align = 'align_' | append: i -%}
    {%- assign s_color = 'color_' | append: i -%}
    {%- assign s_opacity = 'opacity_' | append: i -%}
    {%- assign s_blend = 'blend_mode_' | append: i -%}
    
    {%- assign s_enable_hover = 'enable_hover_' | append: i -%}
    {%- assign s_hover_color = 'hover_color_' | append: i -%}
    {%- assign s_hover_opacity = 'hover_opacity_' | append: i -%}
    {%- assign s_hover_weight = 'hover_weight_' | append: i -%}
    
    {%- assign s_enable_active = 'enable_active_' | append: i -%}
    {%- assign s_active_color = 'active_color_' | append: i -%}
    {%- assign s_active_opacity = 'active_opacity_' | append: i -%}
    {%- assign s_active_weight = 'active_weight_' | append: i -%}
    
    .ai-item-{{ i }}-{{ block_id }} {
      font-size: {{ block.settings[s_size] }}px;
      font-weight: {{ block.settings[s_weight] }};
      line-height: {{ block.settings[s_lh] }};
      text-align: {{ block.settings[s_align] }};
      color: {{ block.settings[s_color] }};
      opacity: {{ block.settings[s_opacity] | divided_by: 100.0 }};
      mix-blend-mode: {{ block.settings[s_blend] }} !important;
      letter-spacing: -0.02em;
      margin: 0 !important; padding: 0 !important;
      transition: color 0.4s ease, opacity 0.4s ease, font-weight 0.4s ease;
      grid-area: 1 / 1;
    }

    .ai-item-{{ i }}-{{ block_id }}-placeholder {
      font-size: {{ block.settings[s_size] }}px;
      font-weight: {{ block.settings[s_weight] }}; 
      line-height: {{ block.settings[s_lh] }};
      text-align: {{ block.settings[s_align] }};
      letter-spacing: -0.02em;
      margin: 0 !important; padding: 0 !important;
      word-wrap: break-word; overflow-wrap: break-word;
      visibility: hidden; pointer-events: none; grid-area: 1 / 1;
    }

    {%- if block.settings[s_enable_hover] -%}
    .ai-column-{{ i }}-{{ block_id }}:hover .ai-item-{{ i }}-{{ block_id }} {
      color: {{ block.settings[s_hover_color] }};
      opacity: {{ block.settings[s_hover_opacity] | divided_by: 100.0 }};
      font-weight: {{ block.settings[s_hover_weight] }};
    }
    {%- endif -%}

    {%- if block.settings[s_enable_active] -%}
    .ai-column-{{ i }}-{{ block_id }}.is-active .ai-item-{{ i }}-{{ block_id }} {
      color: {{ block.settings[s_active_color] }};
      opacity: {{ block.settings[s_active_opacity] | divided_by: 100.0 }};
      font-weight: {{ block.settings[s_active_weight] }};
    }
    {%- endif -%}
  {%- endfor -%}

  @media screen and (max-width: 767px) {
    .ai-text-container-{{ block_id }} {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: wrap !important;
      align-content: flex-start !important;
      {% if block.settings.horizontal_justify == 'flex-start' %}
        justify-content: flex-start !important;
        margin: 0 auto 0 0 !important;
      {% elsif block.settings.horizontal_justify == 'flex-end' %}
        justify-content: flex-end !important;
        margin: 0 0 0 auto !important;
      {% else %}
        justify-content: center !important;
        margin: 0 auto !important;
      {% endif %}
      column-gap: {{ block.settings.mobile_gap_x }}px !important; 
      row-gap: {{ block.settings.mobile_gap_y }}px !important; 
      width: 100% !important;
    }
    
    .ai-column-{{ block_id }} {
      width: auto !important; 
      flex: 0 0 auto !important;
      padding: {{ block.settings.box_padding | times: 0.5 }}px !important;
      margin: 0 !important;
      max-width: calc(100% - 10px); /* 预留微小间隙防止换行死锁 */
    }

    .mobile-line-break-{{ block_id }} {
      flex-basis: 100% !important;
      width: 0 !important;
      height: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      display: block !important;
    }

    .ai-item-wrapper-{{ block_id }} {
      white-space: normal !important; 
      word-break: break-word;
    }

    {%- for i in (1..4) -%}
      {%- assign s_size = 'size_' | append: i -%}
      .ai-item-{{ i }}-{{ block_id }},
      .ai-item-{{ i }}-{{ block_id }}-placeholder {
        font-size: {{ block.settings[s_size] | times: mobile_scale | at_least: 12 }}px;
      }
    {%- endfor -%}
  }
{%- endstyle -%}

<div class="ai-text-wrapper-{{ block_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-container-{{ block_id }}">
    {%- for i in (1..block.settings.visible_columns) -%}
      {%- liquid
        assign s_text = 'text_' | append: i
        assign s_img = 'img_' | append: i
        assign s_vid = 'vid_' | append: i
        assign media_url = ""
        assign media_type = "none"
        
        if block.settings[s_vid] != blank
          assign media_url = block.settings[s_vid].sources[1].url
          assign media_type = "video"
        elsif block.settings[s_img] != blank
          assign media_url = block.settings[s_img] | image_url: width: 2000
          assign media_type = "image"
        endif
      -%}
      
      <div class="ai-column-{{ block_id }} ai-column-{{ i }}-{{ block_id }} js-trigger-bg" 
           data-bg-url="{{ media_url }}" 
           data-bg-type="{{ media_type }}">
        <div class="ai-item-wrapper-{{ block_id }}">
          <div class="ai-item-{{ i }}-{{ block_id }}-placeholder">
            {{ block.settings[s_text] | newline_to_br }}
          </div>
          <div class="ai-item-{{ i }}-{{ block_id }}">
            {{ block.settings[s_text] | newline_to_br }}
          </div>
        </div>
      </div>

      {%- assign check_break = i | modulo: 2 -%}
      {%- if check_break == 0 and i < block.settings.visible_columns -%}
        <div class="mobile-line-break-{{ block_id }} hide-desktop"></div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const wrapper = document.querySelector('.ai-text-wrapper-{{ block_id }}');
    if (!wrapper) return;
    
    wrapper.addEventListener('click', function(e) {
      const trigger = e.target.closest('.js-trigger-bg');
      if (!trigger) return;
      const isActive = trigger.classList.contains('is-active');
      document.querySelectorAll('.js-trigger-bg').forEach(el => el.classList.remove('is-active'));
      if (!isActive) trigger.classList.add('is-active');
    });
    
    // 逻辑：现在的适配逻辑完全由 CSS 媒体查询和 Flex-wrap 处理。
    // 如果您需要动态监控高度，可以在此处添加 ResizeObserver，
    // 但目前自然的 CSS 换行已能满足“屏幕不足时换行”的要求。
  });
</script>

