{%- style -%}
  /* =========================================
     0. 滚动条隐身魔法 (Scrollbar Hidden)
     ========================================= */
  {%- if section.settings.hide_scrollbar -%}
    html::-webkit-scrollbar, 
    body::-webkit-scrollbar, 
    .koto-doc-sidebar::-webkit-scrollbar {
      display: none !important;
      width: 0 !important;
      height: 0 !important;
    }
    html, body, .koto-doc-sidebar {
      -ms-overflow-style: none !important; 
      scrollbar-width: none !important; 
    }
  {%- endif -%}

  /* =========================================
     🌟 渐进式内容浮现 (新加入的动画特效)
     ========================================= */
  .koto-reveal-after-wave {
    opacity: 0;
    transform: translateY(30px);
    /* 延迟 0.9s：等背景波浪退去大半时，内容才开始浮现 */
    animation: kotoContentFadeIn 0.8s cubic-bezier(0.23, 1, 0.32, 1) 0.9s forwards;
  }

  @keyframes kotoContentFadeIn {
    to { 
      opacity: 1; 
      transform: translateY(0); 
    }
  }

  /* =========================================
     1. 终极空间清理
     ========================================= */
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    display: block;
  }

  .koto-master-wrapper-{{ section.id }} {
    position: relative;
    width: 100% !important;
    margin: 0 auto !important;
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    padding-left: {{ section.settings.padding_left }}px !important;
    padding-right: {{ section.settings.padding_right }}px !important;

    {% if section.settings.full_width %}
      max-width: 100% !important;
    {% else %}
      max-width: {{ section.settings.max_width }}px !important;
    {% endif %}

    box-sizing: border-box !important;
    overflow: visible !important;
  }

  /* =========================================
     2. 核心 Grid 布局
     ========================================= */
  .koto-doc-layout-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 3fr; 
    align-items: start;
    width: 100%;
    gap: {{ section.settings.column_gap }}px;
  }

  /* =========================================
     🔥 3. 终极中文排版引擎 (Typography Engine)
     ========================================= */
  .sidebar-title-{{ section.id }},
  .koto-doc-toc-link,
  .koto-doc-heading,
  .koto-grid-title,
  h2, h3 {
    word-break: normal;
    overflow-wrap: break-word; 
    line-break: strict; 
    text-wrap: balance; 
  }

  .sidebar-desc-{{ section.id }},
  .koto-doc-toc-desc,
  .koto-optimize-text,
  .koto-grid-text,
  .koto-inner-content div {
    text-align: justify;
    text-justify: inter-ideograph; 
    word-break: normal; 
    overflow-wrap: break-word; 
    line-break: strict; 
    text-wrap: pretty; 
    hyphens: auto;
  }

  /* 🌟 文字块最大阅读宽度限制 */
  .koto-doc-heading,
  .koto-optimize-text,
  .koto-grid-text {
    max-width: {{ section.settings.text_max_width }}px;
  }

  /* =========================================
     4. 左侧高级目录排版设置
     ========================================= */
  .koto-doc-sidebar {
    position: sticky;
    top: {{ section.settings.sticky_offset }}px;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    margin: 0 !important;
    padding: 0 !important;
    align-self: start;
  }

  .sidebar-title-{{ section.id }} {
    margin-top: 0 !important;
    padding-top: 0 !important;
    margin-bottom: {{ section.settings.sidebar_title_margin_bottom }}px !important;
    line-height: {{ section.settings.title_line_height }};
    color: {{ section.settings.sidebar_title_color }};
    font-size: {{ section.settings.sidebar_title_size }}px;
    font-weight: {{ section.settings.sidebar_title_weight }};
    letter-spacing: {{ section.settings.sidebar_title_spacing }}px;
    text-transform: {{ section.settings.sidebar_title_transform }};
    font-style: {{ section.settings.sidebar_title_style }};
    display: block !important;
  }

  .sidebar-desc-{{ section.id }} {
    margin-bottom: {{ section.settings.sidebar_desc_margin_bottom }}px !important;
    color: {{ section.settings.sidebar_desc_color }};
    font-size: {{ section.settings.sidebar_desc_size }}px;
    font-weight: {{ section.settings.sidebar_desc_weight }};
    letter-spacing: {{ section.settings.sidebar_desc_spacing }}px;
    line-height: {{ section.settings.sidebar_desc_line_height }};
    text-transform: {{ section.settings.sidebar_desc_transform }};
    font-style: {{ section.settings.sidebar_desc_style }};
  }
  .sidebar-desc-{{ section.id }} p, .koto-doc-toc-desc p, .koto-optimize-text p { margin: 0 0 0.8em 0; padding: 0; }
  .sidebar-desc-{{ section.id }} p:last-child, .koto-doc-toc-desc p:last-child, .koto-optimize-text p:last-child { margin: 0; }

  .koto-doc-toc { list-style: none; padding: 0 !important; margin: 0 !important; display: flex; flex-direction: column; gap: {{ section.settings.toc_item_gap }}px; }

  .koto-toc-item {
    opacity: {{ section.settings.toc_inactive_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
    cursor: pointer;
    padding: 4px 0; 
  }
  .koto-toc-item:hover,
  .koto-toc-item.is-active {
    opacity: 1;
  }

  .koto-doc-toc-link { 
    text-decoration: none; display: block; padding: 0 !important; margin: 0 !important;
    color: {{ section.settings.toc_link_color }};
    font-size: {{ section.settings.toc_link_size }}px;
    font-weight: {{ section.settings.toc_link_weight }};
    letter-spacing: {{ section.settings.toc_link_spacing }}px;
    line-height: {{ section.settings.toc_link_line_height }};
    text-transform: {{ section.settings.toc_link_transform }};
    font-style: {{ section.settings.toc_link_style }};
    pointer-events: none; 
  }
  .koto-toc-item.is-active .koto-doc-toc-link { font-weight: 700; }

  .toc-level-h3 .koto-doc-toc-link { font-size: 0.95em; position: relative; padding-left: 20px !important; }
  .toc-level-h3 .koto-doc-toc-link::before { content: "—"; position: absolute; left: 0; opacity: 0.5; }

  .koto-doc-toc-desc {
    color: {{ section.settings.toc_desc_color }};
    font-size: {{ section.settings.toc_desc_size }}px;
    font-weight: {{ section.settings.toc_desc_weight }};
    letter-spacing: {{ section.settings.toc_desc_spacing }}px;
    line-height: {{ section.settings.toc_desc_line_height }};
    text-transform: {{ section.settings.toc_desc_transform }};
    font-style: {{ section.settings.toc_desc_style }};
    margin-top: {{ section.settings.toc_desc_margin_top }}px;
    margin-bottom: 0;
    pointer-events: none; 
  }
  .toc-level-h3 .koto-doc-toc-desc { padding-left: 20px; }

  /* =========================================
     5. 标签引擎
     ========================================= */
  .koto-doc-toc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: {{ section.settings.tag_margin_top }}px;
    margin-bottom: 2px;
    pointer-events: none; 
  }
  .toc-level-h3 .koto-doc-toc-tags { padding-left: 20px; }

  .koto-toc-tag {
    background-color: color-mix(in srgb, {{ section.settings.tag_bg_color }} {{ section.settings.tag_bg_opacity }}%, transparent);
    color: {{ section.settings.tag_text_color }};
    font-size: {{ section.settings.tag_font_size }}px;
    font-weight: {{ section.settings.tag_font_weight }};
    border-radius: {{ section.settings.tag_radius }}px;
    padding: 4px 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    line-height: 1.4;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .koto-back-btn-wrapper {
    margin-bottom: {{ section.settings.back_btn_margin_bottom }}px;
    display: flex;
    align-items: center;
  }
  .koto-back-btn:hover { opacity: 0.8; }
  .koto-back-icon { height: 1.2em; width: auto; object-fit: contain; display: block; }

  /* =========================================
     6. 右侧内容区
     ========================================= */
  .koto-block-card {
    position: relative;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    width: 100%;
    margin-bottom: {{ section.settings.block_margin_bottom }}px;
    box-sizing: border-box !important;
    margin-top: 0 !important;
  }
  .koto-block-card:last-child { margin-bottom: 0; }

  .koto-grid-3col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .koto-grid-2col { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; }

  .koto-media-wrap { width: 100%; border-radius: {{ section.settings.media_radius }}px; overflow: hidden; line-height: 0; }
  .koto-media-wrap video, .koto-media-wrap img { width: 100%; height: auto; display: block; object-fit: cover; }

  .koto-square-media { width: 100%; aspect-ratio: 1 / 1; border-radius: {{ section.settings.media_radius }}px; overflow: hidden; margin-left: auto; margin-right: auto; }
  .koto-square-media img { width: 100%; height: 100%; object-fit: cover; }

  .koto-bg-card-item { position: relative; display: block; overflow: hidden; border-radius: {{ section.settings.media_radius }}px; }
  .koto-abs-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
  .koto-abs-bg img { width: 100%; height: 100%; object-fit: cover; }
  .koto-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 1; }

  .koto-inner-content { 
    position: absolute;
    top: 0; left: 0; 
    width: 100%; 
    height: 100%; 
    z-index: 2;
    display: flex; 
    flex-direction: column; 
    justify-content: space-between; 
    box-sizing: border-box;
  }

  /* =========================================
     🌟 7. 左文右图贴边滑动卡片专属 CSS
     ========================================= */
  .koto-slider-bleed-wrapper {
    display: flex;
    align-items: stretch;
    width: 100%;
    overflow: hidden;
  }
  .koto-slider-text-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    box-sizing: border-box;
  }
  .koto-slider-text-slides {
    position: relative;
    flex: 1;
  }
  .koto-slide-text-item {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between; 
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .koto-slide-text-item.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }
  .koto-slider-controls {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    z-index: 10;
  }
  .koto-slider-btn {
    border-radius: 50%;
    border: 1px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    opacity: 0.4;
    transition: all 0.3s ease;
    overflow: hidden;
  }
  .koto-slider-btn:hover {
    opacity: 1;
    transform: scale(1.05);
  }
  .koto-slider-image-area {
    flex-shrink: 0;
    position: relative;
  }
  .koto-slide-img-item {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .koto-slide-img-item.is-active {
    opacity: 1;
    z-index: 2;
  }
  .koto-slide-img-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 990px) {
    .koto-master-wrapper-{{ section.id }} { padding-left: 20px !important; padding-right: 20px !important; }
    .koto-doc-layout-{{ section.id }} { grid-template-columns: 1fr; }
    .koto-grid-3col, .koto-grid-2col { grid-template-columns: 1fr !important; }
    .koto-doc-sidebar { position: relative; top: 0 !important; margin-bottom: 40px !important; }
    .koto-square-media { width: 100% !important; max-width: 100% !important; }
    
    .koto-slider-bleed-wrapper { flex-direction: column-reverse; }
    .koto-slider-image-area { width: 100% !important; min-height: 300px; }
    .koto-slide-text-item { position: relative; height: auto; display: none; gap: 20px; }
    .koto-slide-text-item.is-active { display: flex; }
    .koto-slider-controls { margin-top: 20px; }
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div id="koto-master-wrapper-{{ section.id }}" class="koto-master-wrapper-{{ section.id }} color-{{ section.settings.color_scheme }}" lang="zh">
  
  {% comment %} 在这里加了 koto-reveal-after-wave 控制内容延迟浮现 {% endcomment %}
  <div class="koto-doc-layout-{{ section.id }} koto-reveal-after-wave">

    <aside class="koto-doc-sidebar">
      {%- if section.settings.sidebar_title != blank -%}
        <h1 class="sidebar-title-{{ section.id }}">{{ section.settings.sidebar_title }}</h1>
      {%- endif -%}

      {%- if section.settings.sidebar_desc != blank -%}
        <div class="sidebar-desc-{{ section.id }}">
          {{ section.settings.sidebar_desc }}
        </div>
      {%- endif -%}

      <ul class="koto-doc-toc">
        {%- for block in section.blocks -%}
          {%- if block.settings.title != blank or block.settings.toc_label != blank or block.settings.main_title != blank -%}
            {%- assign label = block.settings.toc_label | default: block.settings.title | default: block.settings.main_title -%}
            <li class="koto-toc-item toc-level-{{ block.settings.heading_level }}">
              <a href="#block-{{ block.id }}" class="koto-doc-toc-link js-toc-link">{{ label }}</a>

              {%- if block.settings.toc_desc != blank -%}
                <div class="koto-doc-toc-desc">{{ block.settings.toc_desc }}</div>
              {%- endif -%}

              {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank or block.settings.tag_3 != blank -%}
                <div class="koto-doc-toc-tags">
                  {%- if block.settings.tag_1 != blank -%}<span class="koto-toc-tag">{{ block.settings.tag_1 }}</span>{%- endif -%}
                  {%- if block.settings.tag_2 != blank -%}<span class="koto-toc-tag">{{ block.settings.tag_2 }}</span>{%- endif -%}
                  {%- if block.settings.tag_3 != blank -%}<span class="koto-toc-tag">{{ block.settings.tag_3 }}</span>{%- endif -%}
                </div>
              {%- endif -%}

            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </aside>

    <main class="koto-doc-main">

      {%- if section.settings.show_back_btn -%}
        <div class="koto-back-btn-wrapper">
          <a href="{{ section.settings.back_btn_link | default: '#' }}" class="koto-toc-tag koto-back-btn">
            {%- if section.settings.back_btn_icon != blank -%}
              <img src="{{ section.settings.back_btn_icon | image_url: width: 60 }}" alt="Back" class="koto-back-icon" loading="lazy">
            {%- endif -%}
            {%- if section.settings.back_btn_text != blank -%}
              <span>{{ section.settings.back_btn_text }}</span>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}

      <div class="koto-doc-content-shell">
        {%- for block in section.blocks -%}
          
          {%- if block.type == 'slider_bleed_box' -%}
            <style>
              #block-{{ block.id }} {
                padding: 0 !important; 
                border-radius: {{ block.settings.box_radius }}px !important; 
              }
            </style>
          {%- endif -%}

          <div id="block-{{ block.id }}" 
               class="koto-block-card js-scroll-section" 
               style="background-color: {{ block.settings.box_bg_color }}; {% if block.type != 'slider_bleed_box' %}padding: {{ block.settings.box_padding_top }}px {{ block.settings.box_padding_right }}px {{ block.settings.box_padding_bottom }}px {{ block.settings.box_padding_left }}px;{% endif %}"
               {{ block.shopify_attributes }}>

            {%- case block.type -%}

              {%- when 'slider_bleed_box' -%}
                <div class="koto-slider-bleed-wrapper js-koto-slider" style="min-height: {{ block.settings.card_height }}px;">
                  <div class="koto-slider-text-area" style="padding-top: {{ block.settings.box_padding_top }}px; padding-bottom: {{ block.settings.box_padding_bottom }}px; padding-left: {{ block.settings.box_padding_left }}px; padding-right: {{ block.settings.content_gap }}px;">
                    
                    <div class="koto-slider-text-slides">
                      {%- assign slide_count = 0 -%}
                      {%- for i in (1..5) -%}
                        {%- capture img_key -%}image_{{ i }}{%- endcapture -%}
                        {%- capture t_key -%}title_{{ i }}{%- endcapture -%}
                        {%- capture p_key -%}text_{{ i }}{%- endcapture -%}
 
                        {%- if block.settings[img_key] != blank or block.settings[t_key] != blank -%}
                          <div class="koto-slide-text-item js-slide-text {% if slide_count == 0 %}is-active{% endif %}" data-has-content="true">
                            <div class="koto-bleed-title">
                              <h2 class="koto-doc-heading" style="margin: 0; color: {{ block.settings.title_color }}; font-size: {{ block.settings.title_size }}px; font-weight: {{ block.settings.title_weight }}; line-height: {{ block.settings.title_lh }};">{{ block.settings[t_key] }}</h2>
                            </div>
                            <div class="koto-bleed-desc">
                              <div class="koto-optimize-text" style="color: {{ block.settings.desc_color }}; font-size: {{ block.settings.desc_size }}px; font-weight: {{ block.settings.desc_weight }}; line-height: {{ block.settings.desc_lh }}; opacity: 0.9;">{{ block.settings[p_key] }}</div>
                            </div>
                          </div>
                          {%- assign slide_count = slide_count | plus: 1 -%}
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    <div class="koto-slider-controls" style="color: {{ block.settings.title_color }};">
                      <div class="koto-slider-btn js-prev" style="width: {{ block.settings.btn_size }}px; height: {{ block.settings.btn_size }}px; {% if block.settings.prev_btn_icon != blank %}border: none;{% endif %}">
                        {%- if block.settings.prev_btn_icon != blank -%}
                          <img src="{{ block.settings.prev_btn_icon | image_url: width: 100 }}" style="width: 100%; height: 100%; object-fit: contain;" alt="Prev">
                        {%- else -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 40%; height: 40%;"><path d="M15 18l-6-6 6-6"/></svg>
                        {%- endif -%}
                      </div>
                      <div class="koto-slider-btn js-next" style="width: {{ block.settings.btn_size }}px; height: {{ block.settings.btn_size }}px; {% if block.settings.next_btn_icon != blank %}border: none;{% endif %}">
                        {%- if block.settings.next_btn_icon != blank -%}
                          <img src="{{ block.settings.next_btn_icon | image_url: width: 100 }}" style="width: 100%; height: 100%; object-fit: contain;" alt="Next">
                        {%- else -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 40%; height: 40%;"><path d="M9 18l-6-6-6-6"/></svg>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>

                  <div class="koto-slider-image-area" style="width: {{ block.settings.image_width }}%;">
                    {%- assign slide_count_img = 0 -%}
                    {%- for i in (1..5) -%}
                      {%- capture img_key -%}image_{{ i }}{%- endcapture -%}
                      {%- capture t_key -%}title_{{ i }}{%- endcapture -%}
                      {%- if block.settings[img_key] != blank or block.settings[t_key] != blank -%}
                        <div class="koto-slide-img-item js-slide-img {% if slide_count_img == 0 %}is-active{% endif %}">
                           {%- if block.settings[img_key] != blank -%}
                            {{ block.settings[img_key] | image_url: width: 1400 | image_tag: loading: 'lazy' }}
                          {%- endif -%}
                        </div>
                        {%- assign slide_count_img = slide_count_img | plus: 1 -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>

                </div>

              {%- when 'content_unit' -%}
                <div class="koto-media-wrap" style="margin-bottom: {{ block.settings.media_bottom_margin }}px;">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
                  {%- elsif block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h2 class="koto-doc-heading" style="margin: 0 0 {{ block.settings.title_bottom_margin }}px 0; color: {{ block.settings.title_color }}; font-size: {{ block.settings.title_size }}px; font-weight: {{ block.settings.title_weight }}; line-height: {{ block.settings.title_lh }}; text-align: {{ block.settings.text_alignment }} !important;">
                    {{ block.settings.title }}
                  </h2>
                {%- endif -%}
                <div class="koto-grid-3col" style="gap: {{ block.settings.col_gap }}px;">
                  <div class="koto-optimize-text" style="color: {{ block.settings.desc_color }}; font-size: {{ block.settings.desc_size }}px; font-weight: {{ block.settings.desc_weight }}; line-height: {{ block.settings.desc_lh }}; text-align: {{ block.settings.text_alignment }} !important; opacity: 0.9;">{{ block.settings.content }}</div>
                  <div class="koto-optimize-text" style="color: {{ block.settings.desc_color }}; font-size: {{ block.settings.desc_size }}px; font-weight: {{ block.settings.desc_weight }}; line-height: {{ block.settings.desc_lh }}; text-align: {{ block.settings.text_alignment }} !important; opacity: 0.9;">{{ block.settings.col_2_text }}</div>
                  <div class="koto-optimize-text" style="color: {{ block.settings.desc_color }}; font-size: {{ block.settings.desc_size }}px; font-weight: {{ block.settings.desc_weight }}; line-height: {{ block.settings.desc_lh }}; text-align: {{ block.settings.text_alignment }} !important; opacity: 0.9;">{{ block.settings.col_3_text }}</div>
                </div>

              {%- when 'triple_bg_image_box' -%}
                <div class="koto-grid-3col" style="gap: {{ block.settings.image_gap }}px;">
                  {%- for i in (1..3) -%}
                    {%- capture img_key -%}image_{{ i }}{%- endcapture -%}
                    {%- capture t_key -%}title_{{ i }}{%- endcapture -%}
                    {%- capture p_key -%}text_{{ i }}{%- endcapture -%}
                    <div class="koto-bg-card-item" style="min-height: {{ block.settings.card_height }}px; color: {{ block.settings.card_text_color }};">
                      {%- if block.settings[img_key] != blank -%}
                        <div class="koto-abs-bg">{{ block.settings[img_key] | image_url: width: 800 | image_tag: loading: 'lazy' }}</div>
                      {%- endif -%}
                      <div class="koto-overlay" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
                      <div class="koto-inner-content" style="padding: {{ block.settings.card_inner_padding }}px;">
                        <h3 class="koto-grid-title" style="color: inherit; font-size: {{ block.settings.card_title_size }}px; font-weight: {{ block.settings.card_title_weight }}; margin: 0; text-align: {{ block.settings.text_alignment }} !important;">
                          {{ block.settings[t_key] }}
                        </h3>
                        <div class="koto-optimize-text" style="color: inherit; font-size: {{ block.settings.card_desc_size }}px; opacity: 0.9; margin: 0; text-align: {{ block.settings.text_alignment }} !important;">
                          {{ block.settings[p_key] }}
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>

              {%- when 'double_column_box' -%}
                {%- assign img_margin = 'margin-left: auto; margin-right: auto;' -%}
                {%- if block.settings.text_alignment == 'left' -%}
                  {%- assign img_margin = 'margin-left: 0; margin-right: auto;' -%}
                {%- elsif block.settings.text_alignment == 'right' -%}
                  {%- assign img_margin = 'margin-left: auto; margin-right: 0;' -%}
                {%- endif -%}

                <div class="koto-grid-2col" style="gap: {{ block.settings.grid_gap }}px;">
                  {%- for i in (1..6) -%}
                    {%- capture img_key -%}image_{{ i }}{%- endcapture -%}
                    {%- capture t_key -%}title_{{ i }}{%- endcapture -%}
                    {%- capture p_key -%}text_{{ i }}{%- endcapture -%}
                    {%- if block.settings[img_key] != blank -%}
                      <div class="koto-grid-unit">
                        <div class="koto-square-media" style="margin-bottom: {{ block.settings.media_bottom_margin }}px; width: {{ block.settings.img_size }}px; max-width: 100%; {{ img_margin }}">
                          {{ block.settings[img_key] | image_url: width: 800 | image_tag: loading: 'lazy' }}
                        </div>
                        <h3 class="koto-grid-title" style="margin: 0 0 {{ block.settings.title_bottom_margin }}px 0; color: {{ block.settings.title_color }}; font-size: {{ block.settings.title_size }}px; font-weight: {{ block.settings.title_weight }}; line-height: {{ block.settings.title_lh }}; text-align: {{ block.settings.text_alignment }} !important;">
                          {{ block.settings[t_key] }}
                        </h3>
                        <div class="koto-grid-text" style="margin: 0; color: {{ block.settings.desc_color }}; font-size: {{ block.settings.desc_size }}px; font-weight: {{ block.settings.desc_weight }}; line-height: {{ block.settings.desc_lh }}; text-align: {{ block.settings.text_alignment }} !important;">
                          {{ block.settings[p_key] }}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- when 'split_content_box' -%}
                <div class="koto-grid-2col" style="align-items: center; gap: {{ block.settings.content_gap }}px;">
                  <div>
                    <h2 class="koto-doc-heading" style="font-size: {{ block.settings.title_size }}px; margin-bottom: 15px;">{{ block.settings.title }}</h2>
                    <div class="koto-optimize-text" style="font-size: 15px; line-height: 1.7;">{{ block.settings.content }}</div>
                  </div>
                  <div class="koto-media-wrap" style="margin-bottom: 0;">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
                    {%- endif -%}
                  </div>
                </div>

              {%- when 'media_hero_2col' -%}
                <div class="koto-media-wrap" style="margin-bottom: {{ block.settings.media_bottom_margin }}px;">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
                  {%- elsif block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                </div>

                <div style="margin-bottom: {{ block.settings.main_text_bottom_margin }}px;">
                  {%- if block.settings.main_title != blank -%}
                    <h2 class="koto-doc-heading" style="margin: 0 0 15px 0; color: {{ block.settings.main_title_color }}; font-size: {{ block.settings.main_title_size }}px; font-weight: {{ block.settings.main_title_weight }}; line-height: {{ block.settings.main_title_lh }};">{{ block.settings.main_title }}</h2>
                  {%- endif -%}
                  {%- if block.settings.main_desc != blank -%}
                    <div class="koto-optimize-text" style="color: {{ block.settings.main_desc_color }}; font-size: {{ block.settings.main_desc_size }}px; font-weight: {{ block.settings.main_desc_weight }}; line-height: {{ block.settings.main_desc_lh }};">{{ block.settings.main_desc }}</div>
                  {%- endif -%}
                </div>

                <div class="koto-grid-2col" style="gap: {{ block.settings.col_gap }}px;">
                  <div>
                    {%- if block.settings.col_1_title != blank -%}
                      <h3 class="koto-doc-heading" style="margin: 0 0 10px 0; color: {{ block.settings.col_title_color }}; font-size: {{ block.settings.col_title_size }}px; font-weight: {{ block.settings.col_title_weight }}; line-height: {{ block.settings.col_title_lh }};">{{ block.settings.col_1_title }}</h3>
                    {%- endif -%}
                    <div class="koto-optimize-text" style="color: {{ block.settings.col_desc_color }}; font-size: {{ block.settings.col_desc_size }}px; font-weight: {{ block.settings.col_desc_weight }}; line-height: {{ block.settings.col_desc_lh }};">{{ block.settings.col_1_desc }}</div>
                  </div>
                  <div>
                    {%- if block.settings.col_2_title != blank -%}
                      <h3 class="koto-doc-heading" style="margin: 0 0 10px 0; color: {{ block.settings.col_title_color }}; font-size: {{ block.settings.col_title_size }}px; font-weight: {{ block.settings.col_title_weight }}; line-height: {{ block.settings.col_title_lh }};">{{ block.settings.col_2_title }}</h3>
                    {%- endif -%}
                    <div class="koto-optimize-text" style="color: {{ block.settings.col_desc_color }}; font-size: {{ block.settings.col_desc_size }}px; font-weight: {{ block.settings.col_desc_weight }}; line-height: {{ block.settings.col_desc_lh }};">{{ block.settings.col_2_desc }}</div>
                  </div>
                </div>

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    </main>
  </div>
</div>

<script>
  (function() {
    function initKotoVisionJS() {
      const sectionWrapper = document.getElementById('koto-master-wrapper-{{ section.id }}');
      if (!sectionWrapper) return;

      const tocItems = sectionWrapper.querySelectorAll('.koto-toc-item');

      tocItems.forEach(item => {
        item.addEventListener('click', function(e) {
          e.preventDefault(); 
          const link = this.querySelector('.js-toc-link');
          if (!link) return;

          const href = link.getAttribute('href');
          if (!href || !href.includes('#')) return;

          const targetId = href.split('#')[1];
          const target = document.getElementById(targetId);

          if (target) {
            const offset = {{ section.settings.sticky_offset | default: 120 }};
            const bodyRect = document.body.getBoundingClientRect().top;
            const elementRect = target.getBoundingClientRect().top;
            const offsetPosition = (elementRect - bodyRect) - offset;
            window.scrollTo({ 
              top: offsetPosition, 
              behavior: 'smooth' 
            });
          }
        });
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            sectionWrapper.querySelectorAll('.koto-toc-item').forEach(li => li.classList.remove('is-active'));
            const activeLink = sectionWrapper.querySelector(`.js-toc-link[href="#${entry.target.id}"]`);
            if (activeLink) {
              const parentLi = activeLink.closest('.koto-toc-item');
              if (parentLi) parentLi.classList.add('is-active');
            }
          }
        });
      }, { rootMargin: '-15% 0px -60% 0px' });

      sectionWrapper.querySelectorAll('.js-scroll-section').forEach(s => observer.observe(s));

      const bleedSliders = sectionWrapper.querySelectorAll('.js-koto-slider');
      bleedSliders.forEach(slider => {
        const textSlides = slider.querySelectorAll('.js-slide-text');
        const imgSlides = slider.querySelectorAll('.js-slide-img');
        const prevBtn = slider.querySelector('.js-prev');
        const nextBtn = slider.querySelector('.js-next');
        const controls = slider.querySelector('.koto-slider-controls');
        
        let validCount = 0;
        textSlides.forEach(s => { if(s.getAttribute('data-has-content') === 'true') validCount++; });

        if (validCount <= 1 && controls) {
          controls.style.display = 'none';
        }

        let currentIndex = 0;

        function updateBleedSlider() {
          textSlides.forEach((s, idx) => {
            if (idx === currentIndex) s.classList.add('is-active');
            else s.classList.remove('is-active');
          });
          imgSlides.forEach((s, idx) => {
            if (idx === currentIndex) s.classList.add('is-active');
            else s.classList.remove('is-active');
          });
        }

        if (prevBtn) {
          prevBtn.addEventListener('click', (e) => {
            e.preventDefault();
            currentIndex = (currentIndex === 0) ? validCount - 1 : currentIndex - 1;
            updateBleedSlider();
          });
        }
        
        if (nextBtn) {
          nextBtn.addEventListener('click', (e) => {
            e.preventDefault();
            currentIndex = (currentIndex === validCount - 1) ? 0 : currentIndex + 1;
            updateBleedSlider();
          });
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initKotoVisionJS);
    } else {
      initKotoVisionJS();
    }

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', function(e) {
        if (e.detail.sectionId === '{{ section.id }}') {
          initKotoVisionJS();
        }
      });
    }
  })();
</script>

