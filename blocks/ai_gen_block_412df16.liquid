{% doc %}
  @prompt
    生成一个文本框，可以设置文本的所有属性，以及上下左右边距，以及适配后的边距
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-text-block__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-align: {{ block.settings.text_align }};
    text-transform: {{ block.settings.text_transform }};
    word-break: break-word;
  }

  @media screen and (max-width: 749px) {
    .ai-text-block-{{ ai_gen_id }} {
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
      padding-left: {{ block.settings.mobile_padding_left }}px;
      padding-right: {{ block.settings.mobile_padding_right }}px;
    }

    .ai-text-block__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }
  }
{% endstyle %}

<div class="ai-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-block__content-{{ ai_gen_id }}">
    {{ block.settings.text }}
  </div>
</div>

{% schema %}
{
  "name": "自定义文本块",
  "settings": [
    {
      "type": "header",
      "content": "文本内容"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "文本",
      "default": "<p>在此输入您的文本内容</p>"
    },
    {
      "type": "header",
      "content": "文本样式"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文本颜色",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "桌面端字体大小",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "label": "移动端字体大小",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "字体粗细",
      "options": [
        {
          "value": "300",
          "label": "细体"
        },
        {
          "value": "400",
          "label": "正常"
        },
        {
          "value": "500",
          "label": "中等"
        },
        {
          "value": "600",
          "label": "半粗"
        },
        {
          "value": "700",
          "label": "粗体"
        },
        {
          "value": "800",
          "label": "特粗"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "行高",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "字间距",
      "min": -2,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "文本对齐",
      "options": [
        {
          "value": "left",
          "label": "左对齐"
        },
        {
          "value": "center",
          "label": "居中"
        },
        {
          "value": "right",
          "label": "右对齐"
        },
        {
          "value": "justify",
          "label": "两端对齐"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "文本转换",
      "options": [
        {
          "value": "none",
          "label": "无"
        },
        {
          "value": "uppercase",
          "label": "大写"
        },
        {
          "value": "lowercase",
          "label": "小写"
        },
        {
          "value": "capitalize",
          "label": "首字母大写"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "背景"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "桌面端边距"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "左边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "右边距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "移动端边距"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "上边距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "下边距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "label": "左边距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "label": "右边距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "布局"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面端宽度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "自定义文本块"
    }
  ]
}
{% endschema %}