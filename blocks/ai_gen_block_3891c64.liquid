{%- comment -%}
  完美交互与融合版（终极防跳动 + 后台受控轮播提速版）：
  1. 布局分离：大标题绑定顶部，详情按钮绑定底部。
  2. 后台受控：加入 desktop 和 mobile 的上下左右 4 向边距控制。
  3. 混合模式保障：恢复了对背景组件的暴力击穿，确保 mix-blend-mode 穿透全图层生效。
  4. 终极抗抖动：采用字符级 inline-grid 占位技术，让细体字符提前占据粗体的物理宽度。
  5. 轮播完全受控：支持 2-10 秒自由调节。
  6. Safari 终极修复：修复 g/y 等字母底部被切的问题；重构轮播逻辑解决拦截。
  7. 栏位 1 换行与间距升级：加入第一栏专属的独立行高与后侧/下方间距控制。
  8. 终极换行与 Safari 行高修复：修复 Safari 下行高失效问题 (inherit)，强制绝对按单词换行防截断。
  9. Safari 终极防裁切 & 悬浮特效定制：以原生 padding 彻底解决字母尾部截断；将第一栏悬浮加粗动画改为从后往前逆向进行。
  10. 间距权重与动画逻辑特化：解决栏位1间距失效问题（提高CSS权重）；第一栏目标字重改为“首字母最粗(600) -> 尾字母最细(200)”。
  11. 局部字间距控制 (终极防报错版)：保留 0.005em 极高精度 (step: 0.5)，修正 range 最大步数限制为刚好 100 步，解决 Shopify Schema 报错。
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@100..900&display=swap" rel="stylesheet">

{%- liquid
  assign block_id = block.id | replace: '_', '' | downcase
  assign opacity_decimal = block.settings.background_opacity | divided_by: 100.0
  assign bg_color_rgba = block.settings.background_color | color_modify: 'alpha', opacity_decimal
  assign mobile_scale = block.settings.mobile_font_scale | divided_by: 100.0
  assign btn_opacity_decimal = block.settings.info_btn_opacity | divided_by: 100.0
  assign btn_bg_rgba = block.settings.info_btn_bg | color_modify: 'alpha', btn_opacity_decimal
-%}

{%- style -%}
  /* ========================================================
     1. 击穿层叠上下文，确保叠加模式 (mix-blend-mode) 完美生效
  ======================================================== */
  .glacier-wrapper-{{ section.id }},
  .glacier-content-{{ section.id }},
  .glacier-content-{{ section.id }} > *,
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .shopify-block,
  .ai-text-wrapper-{{ block_id }},
  .ai-text-container-{{ block_id }},
  .ai-column-{{ block_id }},
  .ai-item-wrapper-{{ block_id }} {
    z-index: auto !important;
    isolation: auto !important; 
    transform: none !important; 
    backdrop-filter: none !important; 
    perspective: none !important;
  }

  /* ========== 核心布局：两头撑开 & 四向边距 ========== */
  .ai-text-wrapper-{{ block_id }} {
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
    
    height: 100% !important; 
    width: {{ block.settings.desktop_width_percent }}% !important;
    
    padding-top: {{ block.settings.padding_top }}px !important;
    padding-bottom: {{ block.settings.padding_bottom }}px !important; 
    padding-left: {{ block.settings.padding_left }}px !important; 
    padding-right: {{ block.settings.padding_right }}px !important;

    box-sizing: border-box;
    font-family: 'Urbanist', sans-serif;
    pointer-events: none; 

    {% if block.settings.horizontal_justify == 'flex-start' %} margin: 0 auto 0 0 !important;
    {% elsif block.settings.horizontal_justify == 'flex-end' %} margin: 0 0 0 auto !important; {% else %} margin: 0 auto !important;
    {% endif %}
  }

  /* 顶部大标题容器 */
  .ai-text-container-{{ block_id }} {
    pointer-events: auto;
    display: flex; flex-direction: {{ block.settings.desktop_layout }}; flex-wrap: wrap; gap: {{ block.settings.gap }}px;
    width: {% if block.settings.container_width_mode == 'fit' %}fit-content{% else %}100%{% endif %};
    {% if block.settings.desktop_layout == 'column' %} align-items: {{ block.settings.horizontal_justify | replace: 'space-between', 'flex-start' }}; justify-content: {{ block.settings.vertical_align }};
    {% else %} align-items: {{ block.settings.vertical_align }}; justify-content: {{ block.settings.horizontal_justify }};
    {% endif %}
  }

  /* 底部按钮详情容器 */
  .ai-info-panels-container-{{ block_id }} {
    pointer-events: auto;
    display: grid; width: 100%; box-sizing: border-box; mix-blend-mode: normal !important;
  }

  .mobile-line-break-{{ block_id }} { display: none !important;
  }

  /* 字体与字重动画 - 依赖字符级占位防抖 */
  .ai-item-wrapper-{{ block_id }} {
    display: block; width: fit-content;
    max-width: 100%; 
    white-space: normal !important; 
    word-break: keep-all !important;
    overflow-wrap: break-word;
  }
  
  .char-span-{{ block_id }} {
    font-weight: 200;
    transition: font-weight 0.2s linear; transition-delay: 0s !important;
    -webkit-font-smoothing: antialiased;
  }
  
  .js-trigger-bg.is-active .ai-item-wrapper-{{ block_id }} .char-span-{{ block_id }},
  .js-trigger-bg:hover .ai-item-wrapper-{{ block_id }} .char-span-{{ block_id }} {
    font-weight: var(--target-weight, 600);
    transition-delay: var(--char-delay, 0s) !important;
  }

  /* 混色块与样式 */
  {%- for i in (1..4) -%}
    {%- assign s_size = 'size_' | append: i -%} {%- assign s_lh = 'lh_' | append: i -%} {%- assign s_align = 'align_' |
    append: i -%} {%- assign s_color = 'color_' | append: i -%} {%- assign s_opacity = 'opacity_' |
    append: i -%} {%- assign s_blend = 'blend_mode_' | append: i -%}
    .ai-column-{{ i }}-{{ block_id }} {
      min-width: 0;
      padding: {{ block.settings.box_padding }}px; background-color: {{ bg_color_rgba }}; border-radius: {{ block.settings.border_radius }}px;
      transition: background-color 0.2s ease, border-radius 0.2s ease, opacity 0.2s linear; box-sizing: border-box; cursor: pointer; flex: 0 0 auto; max-width: 100%;
      margin: 0 !important; 
      mix-blend-mode: {{ block.settings[s_blend] | default: 'difference' }} !important; opacity: 0.3;
    }
    .ai-column-{{ i }}-{{ block_id }}.is-active, .ai-column-{{ i }}-{{ block_id }}:hover { opacity: 1;
    }
    
    .ai-item-{{ i }}-{{ block_id }} {
      {%- if i == 1 -%}
        font-size: min({{ block.settings[s_size] }}px, {{ block.settings.desktop_size_1_vw | default: 12 }}vw);
      {%- else -%}
        font-size: {{ block.settings[s_size] }}px;
      {%- endif -%}
      line-height: {{ block.settings[s_lh] | default: 1.1 }}; 
      text-align: {{ block.settings[s_align] | default: 'left' }}; 
      letter-spacing: -0.02em; 
      margin: 0 !important;
      padding: 0 0 0.2em 0 !important; 
      color: {{ block.settings[s_color] | default: '#ffffff' }}; 
      opacity: {{ block.settings[s_opacity] | default: 100 | divided_by: 100.0 }};
      transition: color 0.3s ease, opacity 0.3s ease;
    }
  {%- endfor -%}

  /* ================= 栏位 1 专属间距（提高权重绝对生效） ================= */
  .ai-text-container-{{ block_id }} > .ai-column-1-{{ block_id }} {
    {% if block.settings.desktop_layout == 'row' %}
      margin-right: {{ block.settings.margin_after_1 }}px !important;
    {% else %}
      margin-bottom: {{ block.settings.margin_after_1 }}px !important;
    {% endif %}
  }

  /* ================= Safari 专属渲染与裁切优化 ================= */
  @supports (-webkit-hyphens:none) {
    .ai-column-{{ block_id }} {
      will-change: opacity;
      -webkit-mask-image: -webkit-radial-gradient(white, black); 
    }
    .char-span-{{ block_id }} {
      will-change: font-weight;
      line-height: inherit !important; 
    }
    .char-span-{{ block_id }}, .char-span-{{ block_id }} * {
      overflow: visible !important;
    }
  }

  /* 详情及按钮样式 */
  .ai-info-panel-{{ block_id }} { grid-area: 1 / 1;
    display: flex; flex-wrap: wrap;
    justify-content: space-between; align-items: flex-end; row-gap: 24px; column-gap: 40px; visibility: hidden; pointer-events: none;
  }
  .ai-info-panel-{{ block_id }}.is-active { visibility: visible;
    pointer-events: auto; z-index: 2; }
  .ai-info-text-{{ block_id }} { color: {{ block.settings.info_text_color }}; font-family: 'Urbanist', sans-serif; font-size: 18px;
    font-weight: 300; line-height: 1.5;
    max-width: 640px; flex: 1 1 auto; margin: 0; opacity: 0; transition: opacity 0.3s ease;
  }
  .ai-info-panel-{{ block_id }}.is-active .ai-info-text-{{ block_id }} { opacity: 1;
  }
  .ai-info-btn-{{ block_id }} { background-color: {{ btn_bg_rgba }}; color: {{ block.settings.info_btn_text_color }};
    padding: {{ block.settings.info_btn_padding_y }}px {{ block.settings.info_btn_padding_x }}px; border-radius: {{ block.settings.info_btn_radius }}px; font-size: {{ block.settings.info_btn_font_size }}px; text-decoration: none; font-family: 'Urbanist', sans-serif;
    font-weight: 400; backdrop-filter: blur({{ block.settings.info_btn_blur }}px); -webkit-backdrop-filter: blur({{ block.settings.info_btn_blur }}px); white-space: nowrap; display: inline-flex; align-items: center; justify-content: center; opacity: 0;
    transition: opacity 0.3s ease, background-color 0.2s ease, transform 0.2s ease;
  }
  .ai-info-panel-{{ block_id }}.is-active .ai-info-btn-{{ block_id }} { opacity: 1;
  }
  .ai-info-btn-{{ block_id }}:hover { background-color: {{ block.settings.info_btn_bg | color_modify: 'alpha', 1.0 }}; transform: scale(1.02);
  }

  /* 移动端四向边距应用 */
  @media screen and (max-width: 767px) {
    .ai-text-wrapper-{{ block_id }} { 
      padding-top: {{ block.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px !important; 
      padding-left: {{ block.settings.padding_left_mobile }}px !important; 
      padding-right: {{ block.settings.padding_right_mobile }}px !important;
    }
    .ai-text-container-{{ block_id }} { display: flex !important; flex-direction: row !important; flex-wrap: wrap !important; align-content: flex-start !important;
      {% if block.settings.horizontal_justify == 'flex-start' %} justify-content: flex-start !important; margin: 0 auto 0 0 !important;
      {% elsif block.settings.horizontal_justify == 'flex-end' %} justify-content: flex-end !important; margin: 0 0 0 auto !important;
      {% else %} justify-content: center !important; margin: 0 auto !important; {% endif %} column-gap: {{ block.settings.mobile_gap_x }}px !important;
      row-gap: {{ block.settings.mobile_gap_y }}px !important; width: 100% !important; }
    
    .ai-column-{{ block_id }} { width: auto !important;
      flex: 0 0 auto !important; padding: {{ block.settings.box_padding | times: 0.5 }}px !important; margin: 0 !important; max-width: calc(100% - 10px);
    }

    /* 移动端第一栏专属间距 */
    .ai-text-container-{{ block_id }} > .ai-column-1-{{ block_id }} {
      width: 100% !important;
      flex: 0 0 100% !important;
      max-width: 100% !important;
      margin-right: 0 !important; 
      margin-bottom: {{ block.settings.margin_after_1_mobile }}px !important;
    }

    .mobile-line-break-{{ block_id }} { display: none !important;
    }

    {%- for i in (1..4) -%} 
      {%- assign s_size = 'size_' | append: i -%} 
      .ai-item-{{ i }}-{{ block_id }} { 
        {%- if i == 1 -%}
          font-size: clamp(14px, {{ block.settings.mobile_size_1 }}vw, {{ block.settings[s_size] }}px) !important;
        {%- else -%}
          font-size: {{ block.settings[s_size] | times: mobile_scale | at_least: 12 }}px;
        {%- endif -%}
      } 
    {%- endfor -%}

    .ai-info-panel-{{ block_id }} { flex-direction: column;
      align-items: flex-start; row-gap: 20px; }
    .ai-info-text-{{ block_id }} { max-width: 100%; font-size: 15px;
    }
  }
{%- endstyle -%}

<div class="ai-text-wrapper-{{ block_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-container-{{ block_id }}">
    {%- for i in (1..block.settings.visible_columns) -%}
      {%- liquid
        assign s_text = 'text_' | append: i
        assign s_img = 'img_' | append: i
        assign s_vid = 'vid_' | append: i
        assign s_btn_link = 'btn_link_' | append: i
        assign media_url = ""
        assign media_type = "none"
        if block.settings[s_vid] != blank
          assign media_url = block.settings[s_vid].sources[1].url
          assign media_type = "video"
        elsif block.settings[s_img] != blank
          assign media_url = block.settings[s_img] | image_url: width: 2000
          assign media_type = "image"
        endif
      -%}
      <div class="ai-column-{{ block_id }} ai-column-{{ i }}-{{ block_id }} js-trigger-bg {% if i == 1 %}is-active{% endif %}" 
           data-index="{{ i }}" 
           data-bg-url="{{ media_url }}" 
           data-bg-type="{{ media_type }}" 
           data-link="{{ block.settings[s_btn_link] }}"
      >
        <div class="ai-item-wrapper-{{ block_id }}">
          <div class="ai-item-{{ i }}-{{ block_id }} split-text-target-{{ block_id }}"
               {% if i == 1 %}
                 data-custom-spacing-words="{{ block.settings.custom_spacing_words_1 }}"
                 {%- comment -%} 核心修复：除以 100.0 将 0.5 转换为精确的 0.005em {%- endcomment -%}
                 data-custom-spacing-value="{{ block.settings.custom_spacing_value_1 | divided_by: 100.0 }}"
               {% endif %}
          >
             {{ block.settings[s_text] | newline_to_br }}
          </div>
        </div>
      </div>
      {%- assign check_break = i | modulo: 2 -%}
      {%- if check_break == 0 and i < block.settings.visible_columns -%}<div class="mobile-line-break-{{ block_id }} hide-desktop"></div>{%- endif -%}
    {%- endfor -%}
  </div>

  <div class="ai-info-panels-container-{{ block_id }}">
    {%- for i in (1..block.settings.visible_columns) -%}
      {%- liquid
        assign info_text_id = 'info_text_' | append: i
        assign btn_text_id = 'btn_text_' | append: i
        assign btn_link_id = 'btn_link_' | append: i
        assign show_info_id = 'show_info_text_' | append: i
        assign show_btn_id = 'show_btn_' | append: i
        assign current_info_text = block.settings[info_text_id]
        assign current_btn_text = block.settings[btn_text_id]
        assign current_btn_link = block.settings[btn_link_id]
        assign show_info = block.settings[show_info_id]
        assign show_btn = block.settings[show_btn_id]
      -%}
      <div class="ai-info-panel-{{ block_id }} ai-info-panel-item-{{ block_id }} {% if i == 1 %}is-active{% endif %}" data-target-index="{{ i }}">
        {%- if show_info -%}<p class="ai-info-text-{{ block_id }}">{{ current_info_text | newline_to_br }}</p>{%- endif -%}
        {%- if show_btn and current_btn_text != blank -%}
          <a href="{{ current_btn_link | default: '#' }}" class="ai-info-btn-{{ block_id }}">{{ current_btn_text }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  function initInteractiveColumns_{{ block_id }}() {
    const wrapper = document.querySelector('.ai-text-wrapper-{{ block_id }}');
    if (!wrapper) return;
    
    wrapper.querySelectorAll('.split-text-target-{{ block_id }}').forEach(element => {
      const isFirstColumn = element.classList.contains('ai-item-1-{{ block_id }}');
      
      const customWordsStr = element.getAttribute('data-custom-spacing-words');
      const customSpacingValStr = element.getAttribute('data-custom-spacing-value');
      
      const customSpacingWords = customWordsStr ? parseInt(customWordsStr, 10) : 0;
      const customSpacingVal = customSpacingValStr ? parseFloat(customSpacingValStr) : 0;
      
      let globalWordCount = 0; 
      
      const childNodes = Array.from(element.childNodes);
      element.innerHTML = '';
      let charIndex = 0; let totalChars = 0;
      childNodes.forEach(node => { if (node.nodeType === Node.TEXT_NODE) totalChars += node.textContent.replace(/\s/g, '').length; });
      const startWeight = 200; const endWeight = 600; const step = totalChars > 1 ? (endWeight - startWeight) / (totalChars - 1) : 0;
      
      childNodes.forEach(node => {
        if (node.nodeType === Node.TEXT_NODE) {
          const words = node.textContent.split(/(\s+)/);
          words.forEach(word => {
            if (/\s/.test(word)) { 
              element.appendChild(document.createTextNode(word));
            } else if (word.length > 0) {
              const wordWrapper = document.createElement('span');
              wordWrapper.style.display = 'inline-block';
              wordWrapper.style.whiteSpace = 'nowrap';
              wordWrapper.style.lineHeight = 'inherit';
              wordWrapper.setAttribute('aria-hidden', 'true');
              
              if (globalWordCount < customSpacingWords && customSpacingVal !== 0) {
                wordWrapper.style.letterSpacing = `${customSpacingVal}em`;
              }
               
              for (let i = 0; i < word.length; i++) {
                const char = word[i];
                
                const targetWeight = isFirstColumn 
                  ? Math.round(endWeight - charIndex * step) 
                  : Math.round(startWeight + charIndex * step);
                
                const charWrapper = document.createElement('span');
                charWrapper.style.display = 'inline-grid';
                charWrapper.style.justifyItems = 'center';
                charWrapper.style.alignItems = 'baseline';
                charWrapper.style.lineHeight = 'inherit';
                
                const boldPlaceholder = document.createElement('span');
                boldPlaceholder.textContent = char;
                boldPlaceholder.style.fontWeight = targetWeight;
                boldPlaceholder.style.visibility = 'hidden';
                boldPlaceholder.style.gridArea = '1 / 1';
                boldPlaceholder.style.pointerEvents = 'none';
                boldPlaceholder.style.lineHeight = 'inherit';
                const visibleSpan = document.createElement('span');
                visibleSpan.textContent = char; 
                visibleSpan.className = 'char-span-{{ block_id }}';
                visibleSpan.style.setProperty('--target-weight', targetWeight);
                
                let delayIndex = isFirstColumn ?
                  (totalChars - 1 - charIndex) : charIndex;
                visibleSpan.style.setProperty('--char-delay', `${delayIndex * 0.005}s`);
                
                visibleSpan.style.gridArea = '1 / 1';
                visibleSpan.style.lineHeight = 'inherit';
                
                charWrapper.appendChild(boldPlaceholder);
                charWrapper.appendChild(visibleSpan);
                wordWrapper.appendChild(charWrapper);
                
                charIndex++;
              }
              element.appendChild(wordWrapper);
              globalWordCount++;
            }
          });
        } else { 
          element.appendChild(node.cloneNode(true));
        }
      });
    });

    const triggers = Array.from(wrapper.querySelectorAll('.js-trigger-bg'));
    const totalItems = {{ block.settings.visible_columns | default: 4 }};
    let currentActiveIdx = 1; 
    
    let baseInterval = {{ block.settings.autoplay_interval | default: 4 | times: 1000 }};
    let currentInterval = baseInterval;
    let autoPlayTimer = null;

    const activateTab = (targetIndex, isHumanClick = false) => {
      if (isHumanClick) { 
        currentInterval = baseInterval + 2000;
      } else {
        currentInterval = baseInterval;
      }

      triggers.forEach(el => el.classList.remove('is-active'));
      wrapper.querySelectorAll('.ai-info-panel-item-{{ block_id }}').forEach(el => el.classList.remove('is-active'));
      
      const trigger = wrapper.querySelector(`.js-trigger-bg[data-index="${targetIndex}"]`);
      if (trigger) trigger.classList.add('is-active');

      const targetPanel = wrapper.querySelector(`.ai-info-panel-item-{{ block_id }}[data-target-index="${targetIndex}"]`);
      if (targetPanel) targetPanel.classList.add('is-active');
      
      currentActiveIdx = parseInt(targetIndex);
      if (trigger && !isHumanClick) {
        trigger.dispatchEvent(new MouseEvent('mouseenter', { bubbles: true, cancelable: true }));
      }
      
      startAutoPlay();
    };
    const playNext = () => {
      let nextIdx = currentActiveIdx + 1;
      if (nextIdx > totalItems) nextIdx = 1;
      activateTab(nextIdx, false); 
    };
    const startAutoPlay = () => { 
      clearTimeout(autoPlayTimer); 
      autoPlayTimer = setTimeout(playNext, currentInterval); 
    };
    setTimeout(() => { startAutoPlay(); }, 100);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearTimeout(autoPlayTimer); 
      } else {
        startAutoPlay(); 
      }
    });
    triggers.forEach(trigger => {
      if (trigger.dataset.clickBound) return;
      trigger.dataset.clickBound = true;
      
      trigger.addEventListener('click', function(e) {
        const targetIndex = trigger.getAttribute('data-index');
        
        if (trigger.classList.contains('is-active')) {
          e.preventDefault(); e.stopPropagation();
          if (e.isTrusted) { 
             const targetLink = trigger.getAttribute('data-link'); 
             if (targetLink && targetLink !== "" && targetLink !== "#") window.location.href = targetLink; 
          }
          return; 
        }
        
        activateTab(targetIndex, e.isTrusted);
        
        if (e.isTrusted) {
          trigger.dispatchEvent(new MouseEvent('mouseenter', { bubbles: true, cancelable: true }));
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initInteractiveColumns_{{ block_id }});

  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.querySelector('.ai-text-wrapper-{{ block_id }}')) {
        initInteractiveColumns_{{ block_id }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "互動多栏文本",
  "settings": [
    { "type": "header", "content": "全局佈局控制" },
    { "type": "range", "id": "autoplay_interval", "label": "自動輪播間隔 (秒)", "min": 2, "max": 10, "step": 1, "default": 4 },
    { "type": "range", "id": "visible_columns", "label": "顯示欄數", "min": 1, "max": 4, "step": 1, "default": 4 },
    { "type": "select", "id": "desktop_layout", "label": "桌面端排列方式", "options": [{"value":"row","label":"橫向排列 (Row)"},{"value":"column","label":"縱向排列 (Column)"}], "default": "row" },
