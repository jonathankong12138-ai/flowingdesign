<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Urbanist:wght@400;500;600&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
{{ "fd-project-detail.css" | asset_url | stylesheet_tag }}

<style>
  .template-project-detail--case .contact-form,
  .template-project-detail--case .shopify-section:has(.contact-form) {
    display: none !important;
  }

  {%- if is_integrated_case -%}
    .integrated-loading-cover-{{ section.id }} {
      position: fixed;
      inset: 0;
      z-index: 2147483000;
      display: grid;
      place-items: center;
      background: #ffffff;
      opacity: 1;
      visibility: visible;
      transition: opacity 0.72s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.72s;
      pointer-events: auto;
    }

    .integrated-loading-cover-{{ section.id }}.is-leaving {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .integrated-loading-logo-{{ section.id }} {
      color: #000;
      font-family: "Urbanist", "Noto Sans SC", sans-serif;
      font-size: 42px;
      line-height: 1;
      letter-spacing: 0;
      white-space: nowrap;
      user-select: none;
    }

    .integrated-loading-word-{{ section.id }} {
      display: inline-block;
      white-space: nowrap;
    }

    .integrated-loading-char-{{ section.id }} {
      display: inline-block;
      font-weight: 400;
      transform-origin: 50% 70%;
      animation: integratedLoadingBreath-{{ section.id }} 1.55s cubic-bezier(0.45, 0, 0.2, 1) infinite;
      animation-delay: calc(var(--char-index, 0) * -0.055s);
      will-change: opacity, transform;
    }

    @keyframes integratedLoadingBreath-{{ section.id }} {
      0%,
      100% {
        opacity: 0.38;
        transform: translate3d(0, 1.5px, 0) scale(0.985);
      }
      50% {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1.005);
      }
    }

    body.integrated-loading-active-{{ section.id }} {
      overflow: hidden;
    }

    @media (prefers-reduced-motion: reduce) {
      .integrated-loading-cover-{{ section.id }},
      .integrated-loading-char-{{ section.id }} {
        transition-duration: 0.01ms;
        animation: none;
      }

      .integrated-loading-char-{{ section.id }} {
        opacity: 1;
        font-weight: 400;
        transform: none;
      }
    }
  {%- endif -%}
</style>

