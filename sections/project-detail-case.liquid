  <section class="m-media m-ratio-medium m-structure-image m-structure-components" data-bg-count="3" data-bg-index="0">
    {%- if is_gtm_case -%}
      <video class="gtm-section-video" src="{{ "fd-project-detail-gtm-section-10-mobile.mp4" | asset_url }}" autoplay muted loop playsinline preload="metadata" aria-label="第十板块移动端视频"></video>
    {%- elsif is_integrated_case -%}
      <canvas class="glacier-wave-bg glacier-wave-bg--bf" data-glacier-wave aria-hidden="true"></canvas>
      <div class="integrated-libs-marquee integrated-libs-marquee--mobile" aria-hidden="true">
        {%- for row_index in (1..2) -%}
          <div class="integrated-libs-row integrated-libs-row--{{ row_index }}">
            <div class="integrated-libs-track">
              {%- for copy_index in (1..4) -%}
                <img src="{{ "fd-project-detail-integrated-libs.webp" | asset_url }}" width="9963" height="1200" alt="" loading="eager">
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <canvas class="glacier-wave-bg" data-glacier-wave aria-hidden="true"></canvas>
      <div class="m-img" aria-hidden="true"></div>
      <div class="m-component-preview" aria-hidden="true">
        <div class="c-libs-marquee-track">
          <img src="{{ "fd-project-detail-dc6ece9570-asset.png" | asset_url }}" width="1200" height="720" alt="" loading="eager">
          <img src="{{ "fd-project-detail-dc6ece9570-asset.png" | asset_url }}" width="1200" height="720" alt="" loading="eager">
        </div>
      </div>
      <div class="m-overlay m-arrow-row">
        <button class="m-arrow m-arrow--dark" type="button" aria-label="上一张背景图" data-bg-step="-1"></button>
        <button class="m-arrow m-arrow--dark m-arrow--next" type="button" aria-label="下一张背景图" data-bg-step="1"></button>
        <span class="m-switch-count" aria-live="polite">01 / 03</span>
      </div>
      <div class="m-overlay m-card-label">
        <div class="m-card-label__title blend-difference"></div>
        <div class="m-card-label__sub"></div>
      </div>
    {%- endif -%}
  </section>
  <section class="m-final-mobile" id="m-mobile-final" data-mobile-final-index="0" data-mobile-final-count="{% if is_integrated_case %}1{% else %}{{ section.settings.mobile_final_image_count | default: 3 }}{% endif %}" aria-label="页面浏览预览">
    <canvas class="glacier-wave-bg{% if is_gtm_case %} glacier-wave-bg--gtm{% elsif is_integrated_case %} glacier-wave-bg--bf{% endif %}" data-glacier-wave aria-hidden="true"></canvas>
    <div class="m-final-mobile__head">
      <div class="m-final-mobile__controls">
        <button class="m-arrow m-arrow--dark" type="button" aria-label="上一张页面浏览图片" data-mobile-final-step="-1"></button>
        <button class="m-arrow m-arrow--dark m-arrow--next" type="button" aria-label="下一张页面浏览图片" data-mobile-final-step="1"></button>
        <span class="m-switch-count" aria-live="polite">01 / 03</span>
      </div>
    </div>
    <div class="m-final-mobile__frame">
    </div>
  </section>
</main>

<section class="outro" data-screen-label="04 Outro">
  <div class="outro-pin">
    <div class="outro-pane outro-next" id="outroNext">
      <canvas class="outro-wave-canvas{% if is_gtm_case %} outro-wave-canvas--dark{% endif %}{% if is_integrated_case %} outro-wave-canvas--integrated-default{% endif %}" id="outroWaveCanvas" aria-hidden="true"></canvas>
      <div class="outro-next-scale">
        <div class="next-header">
          <span class="next-eyebrow">下一个项目</span>
          <span class="next-title blend-difference">{{ next_project_title }}</span>
          <a class="next-cta-arrow" href="#" aria-label="查看下一个项目" onclick="event.preventDefault()"></a>
        </div>
        <div class="next-bottom">
          <div class="next-footer-bottom next-footer-anim delay-3">
            <div class="next-footer-note-head">
              <p class="next-footer-note-title">重新浏览当前项目，<a class="next-footer-back-link" href="#" onclick="return window.fdProjectBackToTop ? window.fdProjectBackToTop(event) : false;">返回顶部</a></p>
            </div>
            <p class="next-footer-note-desc">All visual works, design concepts, interface mockups, branding explorations, and original imagery presented on this website are the intellectual property of the author and are protected under copyright law.<br><br>© 2026. All rights reserved.</p>
          </div>
        </div>
        {%- liquid
          assign is_integrated_outro = is_integrated_case
          if request.path contains '/pages/integrated-marketing-design'
            assign is_integrated_outro = true
          endif
          assign next_thumb_video_asset = 'home-bfcm-video.mp4'
          if is_integrated_outro
            assign next_thumb_video_asset = 'home-user-video.mp4'
          endif
        -%}
        <div class="next-thumb" role="link" aria-label="Next project preview">
          <video class="next-thumb-video" src="{{ next_thumb_video_asset | asset_url }}" autoplay muted loop playsinline preload="metadata" aria-hidden="true"></video>
          {%- unless is_integrated_outro -%}
            <div class="next-thumb-carousel" aria-hidden="true">
              <img src="{{ "home-bfcm-1.webp" | asset_url }}" width="1600" height="900" loading="lazy" alt="">
              <img src="{{ "home-bfcm-2.webp" | asset_url }}" width="1600" height="900" loading="lazy" alt="">
              <img src="{{ "home-bfcm-3.webp" | asset_url }}" width="1600" height="900" loading="lazy" alt="">
            </div>
          {%- endunless -%}
        </div>
      </div>
    </div>
  </div>
</section>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" defer></script>
<script src="{{ "fd-project-detail.js" | asset_url }}" defer></script>

