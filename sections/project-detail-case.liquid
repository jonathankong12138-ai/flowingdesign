{%- if is_integrated_case -%}
  <div id="integrated-loading-cover-{{ section.id }}" class="integrated-loading-cover-{{ section.id }}" data-integrated-loading-cover aria-hidden="true">
    <div class="integrated-loading-logo-{{ section.id }}" data-integrated-loading-logo>Flowin’ Design</div>
  </div>

  <script>
    (function () {
      const sectionId = {{ section.id | json }};
      const cover = document.getElementById('integrated-loading-cover-' + sectionId);
      const logo = cover?.querySelector('[data-integrated-loading-logo]');
      if (!cover || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        cover?.remove();
        return;
      }

      if (cover.parentNode !== document.body) {
        document.body.appendChild(cover);
      }

      const wait = (ms) => new Promise(resolve => window.setTimeout(resolve, ms));
      const splitLogo = () => {
        if (!logo || logo.dataset.split === 'true') return;
        const text = logo.textContent || '';
        let charIndex = 0;
        logo.innerHTML = '';

        text.split(/(\s+)/).forEach(part => {
          if (!part) return;
          if (/^\s+$/.test(part)) {
            logo.appendChild(document.createTextNode(part));
            return;
          }

          const word = document.createElement('span');
          word.className = 'integrated-loading-word-' + sectionId;
          Array.from(part).forEach(char => {
            const span = document.createElement('span');
            span.className = 'integrated-loading-char-' + sectionId;
            span.textContent = char;
            span.style.setProperty('--char-index', charIndex);
            word.appendChild(span);
            charIndex++;
          });
          logo.appendChild(word);
        });

        logo.dataset.split = 'true';
      };

      const waitForHeroVideo = () => new Promise(resolve => {
        const selector = window.matchMedia('(max-width: 768px)').matches ? '.mobile-hero-video' : '.c-hero-video';
        const video = document.querySelector('.fd-project-detail-section--integrated-marketing-design ' + selector);
        if (!video || video.readyState >= 2) {
          resolve(true);
          return;
        }

        const done = () => {
          video.removeEventListener('loadeddata', done);
          video.removeEventListener('canplay', done);
          video.removeEventListener('error', done);
          resolve(true);
        };
        video.addEventListener('loadeddata', done, { once: true });
        video.addEventListener('canplay', done, { once: true });
        video.addEventListener('error', done, { once: true });
        window.setTimeout(done, 1800);
      });

      const run = () => {
        splitLogo();
        document.body.classList.add('integrated-loading-active-' + sectionId);
        Promise.all([wait(1600), waitForHeroVideo()]).finally(() => {
          cover.classList.add('is-leaving');
          document.body.classList.remove('integrated-loading-active-' + sectionId);
          window.setTimeout(() => cover.remove(), 820);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run, { once: true });
      } else {
        run();
      }
    })();
  </script>
{%- endif -%}

