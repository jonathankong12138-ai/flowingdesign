{{ "fd-project-detail.css" | asset_url | stylesheet_tag }}

<style>
  .template-project-detail--case .contact-form,
  .template-project-detail--case .shopify-section:has(.contact-form) {
    display: none !important;
  }

  {%- if is_integrated_case -%}
    .integrated-loading-cover-{{ section.id }} {
      position: fixed;
      inset: 0;
      z-index: 2147483000;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.70);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      opacity: 1;
      visibility: visible;
      transition: opacity 0.72s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.72s, backdrop-filter 0.72s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: auto;
    }

    .integrated-loading-cover-{{ section.id }}.is-leaving {
      opacity: 0;
      visibility: hidden;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      pointer-events: none;
    }

    .integrated-loading-logo-{{ section.id }} {
      color: #000;
      font-family: "Urbanist", "Noto Sans SC", sans-serif;
      font-size: 42px;
      line-height: 1;
      letter-spacing: 0;
      white-space: nowrap;
      user-select: none;
    }

    .integrated-loading-word-{{ section.id }} {
      display: inline-block;
      white-space: nowrap;
    }

    .integrated-loading-char-{{ section.id }} {
      display: inline-block;
      font-weight: 200;
      animation: integratedLoadingBreath-{{ section.id }} 1s ease-in-out infinite;
      animation-delay: calc(var(--char-index, 0) * 0.018s);
      will-change: opacity, font-weight;
    }

    @keyframes integratedLoadingBreath-{{ section.id }} {
      0%,
      100% {
        opacity: 0.42;
        font-weight: 200;
      }
      50% {
        opacity: 1;
        font-weight: var(--target-weight, 600);
      }
    }

    body.integrated-loading-active-{{ section.id }} {
      overflow: hidden;
    }

    @media (prefers-reduced-motion: reduce) {
      .integrated-loading-cover-{{ section.id }},
      .integrated-loading-char-{{ section.id }} {
        transition-duration: 0.01ms;
        animation: none;
      }

      .integrated-loading-char-{{ section.id }} {
        opacity: 1;
        font-weight: 400;
      }
    }
  {%- endif -%}
</style>

