{%- comment -%}
  Glacier Dune 动态背景 (完美滚动阻尼版 - 修復小數點報錯)
  1. 彻底解决预览模式下无法滚动的 Bug。
  2. 新增：白浪滚屏物理惯性 (Scroll Lerp)，滚动时如弹簧般丝滑跟随。
  3. 修復 Shopify Schema 不支援兩位小數點的限制。
{%- endcomment -%}

{%- liquid
  assign section_id = section.id | replace: '-', '_'
  assign mask_opacity_raw = section.settings.mask_opacity | default: 90
  assign mask_opacity = mask_opacity_raw | divided_by: 100.0
  assign default_mask_color = section.settings.mask_color | default: '#FFFFFF'
  assign mask_color_rgba = default_mask_color | color_modify: 'alpha', mask_opacity
-%}

{%- if section.settings.background_media == 'glacier_dune' -%}
  <style>
    .glacier-wrapper-{{ section.id }} {
      position: relative !important;
      width: 100% !important; 
      height: 100vh !important; 
      background: transparent !important;
      margin: 0 !important;
      padding: 0 !important;
    }
    
    .glacier-global-bg-{{ section.id }} {
      position: fixed !important; 
      top: 0 !important;
      left: 0 !important; 
      width: 100vw !important; 
      height: 100vh !important;
      height: 100dvh !important;
      z-index: -999 !important; 
      pointer-events: none !important; 
    }

    .glacier-canvas-{{ section.id }} {
      position: absolute !important;
      top: 0; left: 0; width: 100%; height: 100%;
      transition: opacity 1s ease-in-out;
    }

    .glacier-media-layer-{{ section.id }} {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
      opacity: 0; 
      transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: none;
    }
    .glacier-media-layer-{{ section.id }}.active { opacity: 1 !important; }

    .glacier-media-content-{{ section.id }} {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    .glacier-media-item-{{ section.id }} {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.42s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.42s;
      will-change: opacity;
    }

    .glacier-media-item-{{ section.id }}.is-active {
      opacity: 1;
      visibility: visible;
    }

    .glacier-media-item-{{ section.id }}.is-warming {
      opacity: 0;
      visibility: visible;
    }

    .glacier-bfcm-carousel-{{ section.id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      z-index: 3;
      overflow: hidden;
      transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.7s;
    }

    .glacier-bfcm-carousel-{{ section.id }}.active {
      opacity: 1;
      visibility: visible;
    }

    .glacier-bfcm-carousel-{{ section.id }} img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: right center;
      opacity: 0;
      transform: none;
      transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .glacier-bfcm-carousel-{{ section.id }} img.is-active {
      opacity: 1;
      transform: none;
    }
    
    .glacier-mask-{{ section.id }} {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100vh; 
      background-color: {{ mask_color_rgba }};
      backdrop-filter: blur({{ section.settings.mask_blur | default: 20 }}px);
      -webkit-backdrop-filter: blur({{ section.settings.mask_blur | default: 20 }}px);
      {% if section.settings.enable_mask_animation %}
        animation: shrinkUp-{{ section.id }} {{ section.settings.animation_duration | default: 1.8 }}s {{ section.settings.animation_curve | default: 'ease-out' }} {{ section.settings.animation_delay | default: 0.3 }}s forwards;
      {% else %}
        height: {{ section.settings.mask_final_height | default: 600 }}px;
      {% endif %}
    }
    
    @keyframes shrinkUp-{{ section.id }} {
      0% { height: 100vh; }
      100% { height: {{ section.settings.mask_final_height | default: 600 }}px; }
    }
    
    .is-media-mode-{{ section.id }} .glacier-canvas-{{ section.id }} { opacity: 0 !important; }
    .is-media-mode-{{ section.id }} .glacier-media-layer-{{ section.id }} { opacity: 1 !important; }
    .is-media-mode-{{ section.id }} .glacier-mask-{{ section.id }} {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    .glacier-content-{{ section.id }} { 
      position: absolute !important;
      top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important;
      z-index: 2; 
      display: flex !important;
      flex-direction: column !important;
      pointer-events: none;
    }
    
    .glacier-content-{{ section.id }} > * {
      flex: 1 1 100% !important;
      width: 100% !important;
      height: 100% !important;
      pointer-events: none;
    }

    .home-loading-cover-{{ section.id }} {
      position: fixed;
      inset: 0;
      z-index: 2147483000;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.56);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      opacity: 1;
      visibility: visible;
      transition: opacity 0.72s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.72s, backdrop-filter 0.72s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: auto;
    }

    .home-loading-cover-{{ section.id }}.is-leaving {
      opacity: 0;
      visibility: hidden;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      pointer-events: none;
    }

    .home-loading-logo-{{ section.id }} {
      color: #000;
      font-size: 42px;
      line-height: 1;
      letter-spacing: 0;
      white-space: nowrap;
      user-select: none;
    }

    .home-loading-word-{{ section.id }} {
      display: inline-block;
      white-space: nowrap;
    }

    .home-loading-char-{{ section.id }} {
      display: inline-block;
      font-weight: 200;
      animation: homeLoadingBreath-{{ section.id }} 1s ease-in-out infinite;
      animation-delay: calc(var(--char-index, 0) * 0.018s);
      will-change: opacity, font-weight;
    }

    @keyframes homeLoadingBreath-{{ section.id }} {
      0%,
      100% {
        opacity: 0.42;
        font-weight: 200;
      }
      50% {
        opacity: 1;
        font-weight: var(--target-weight, 600);
      }
    }

    body.home-loading-active-{{ section.id }} {
      overflow: hidden;
    }

    @media (prefers-reduced-motion: reduce) {
      .home-loading-cover-{{ section.id }},
      .home-loading-char-{{ section.id }} {
        transition-duration: 0.01ms;
        animation: none;
      }

      .home-loading-char-{{ section.id }} {
        opacity: 1;
        font-weight: 400;
      }
    }
  </style>

  <div id="glacier-global-bg-{{ section.id }}" class="glacier-global-bg-{{ section.id }}">
    <div id="media-layer-{{ section.id }}" class="glacier-media-layer-{{ section.id }}">
      <div id="media-content-{{ section.id }}" class="glacier-media-content-{{ section.id }}"></div>
    </div>
    <div id="bfcm-carousel-{{ section.id }}" class="glacier-bfcm-carousel-{{ section.id }}" aria-hidden="true"></div>
    <canvas id="canvas-{{ section.id }}" class="glacier-canvas-{{ section.id }}"></canvas>
    <div class="glacier-mask-{{ section.id }}"></div>
  </div>

  <div id="home-loading-cover-{{ section.id }}" class="home-loading-cover-{{ section.id }}" data-home-loading-cover aria-hidden="true">
    <div class="home-loading-logo-{{ section.id }}" data-home-loading-logo>Flowin’ Design</div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" defer></script>
  
  <script id="vs-{{ section.id }}" type="x-shader/x-vertex">
    varying vec2 vUv;
    void main() { vUv = uv; gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }
  </script>
  
  <script id="fs-{{ section.id }}" type="x-shader/x-fragment">
    uniform float uTime; uniform vec2 uResolution;
    uniform float uScroll; uniform float uRandomSeed;
    uniform float uContrast; uniform float uBrightness;
    uniform float uHueShift; uniform float uSaturation;
    uniform float uThemeSpeed; uniform float uThemeDetail;
    uniform float uWaveFreq; uniform float uDistortion;
    uniform float uMaskSmooth; uniform float uCrestSize;
    uniform float uWaveSpeed; 
    uniform float uWaveCurve; 
    uniform vec3 uColorAmbient; uniform vec3 uColorDeep; uniform vec3 uColorMid;
    uniform vec3 uColorSoft; uniform vec3 uColorHigh; uniform vec3 uColorSpec;
    uniform float uStop1; uniform float uStop2; uniform float uStop3; uniform float uStop4;
    uniform vec3 uWaveColor; uniform vec3 uCrestColor;
    uniform float uLightX; uniform float uLightY;
    uniform float uGrainIntensity; uniform float uGrainScale; uniform float uGrainSpeed;
    varying vec2 vUv;
    
    mat2 rotate2d(float angle){ return mat2(cos(angle), -sin(angle), sin(angle), cos(angle)); }
    vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }
    float snoise(vec2 v){
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy)); vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1; i = mod(i, 289.0);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0; vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5); vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y; g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
    }
    
    float getHeight(vec2 uv, float time, float scroll, float seed) {
        vec2 seedOffset = vec2(seed * 10.3, seed * 4.2);
        vec2 baseUV = uv + seedOffset + vec2(0.0, scroll * 0.2); 
        float flowTime = time * uThemeSpeed + scroll * 0.5;
        vec2 rotUV = rotate2d(-0.5) * baseUV;
        vec2 distortion = vec2(0.0);
        distortion.x = snoise(rotUV * 0.5 + vec2(flowTime * 0.15, flowTime * 0.1));
        distortion.y = snoise(rotUV * 0.5 - vec2(flowTime * 0.1, flowTime * 0.1));
        float detail = snoise(rotUV * (1.5 * uThemeDetail) + distortion + flowTime * 0.1) * (0.1 * uThemeDetail);
        float wave = sin(rotUV.y * uWaveFreq + distortion.x * uDistortion + flowTime);
        return pow(max(wave * 0.5 + 0.5, 0.0), 0.8) + detail;
    }
    
    vec3 rgb2hsl(vec3 c){
        float maxC = max(c.r, max(c.g, c.b)); float minC = min(c.r, min(c.g, c.b));
        float h, s, l = (maxC + minC) / 2.0;
        if(maxC == minC){ h = s = 0.0; }
        else{
            float d = maxC - minC;
            s = l > 0.5 ? d / (2.0 - maxC - minC) : d / (maxC + minC);
            if(maxC == c.r) h = (c.g - c.b) / d + (c.g < c.b ? 6.0 : 0.0);
            else if(maxC == c.g) h = (c.b - c.r) / d + 2.0;
            else h = (c.r - c.g) / d + 4.0;
            h /= 6.0;
        }
        return vec3(h, s, l);
    }
    
    float hue2rgb(float p, float q, float t){
        if(t < 0.0) t += 1.0; if(t > 1.0) t -= 1.0;
        if(t < 1.0/6.0) return p + (q - p) * 6.0 * t;
        if(t < 1.0/2.0) return q;
        if(t < 2.0/3.0) return p + (q - p) * (2.0/3.0 - t) * 6.0;
        return p;
    }
    
    vec3 hsl2rgb(vec3 c){
        vec3 rgb;
        if(c.y == 0.0){ rgb = vec3(c.z); }
        else{
            float q = c.z < 0.5 ? c.z * (1.0 + c.y) : c.z + c.y - c.z * c.y;
            float p = 2.0 * c.z - q;
            rgb.r = hue2rgb(p, q, c.x + 1.0/3.0);
            rgb.g = hue2rgb(p, q, c.x);
            rgb.b = hue2rgb(p, q, c.x - 1.0/3.0);
        }
        return rgb;
    }
    
    void main() {
        vec2 uv = vUv;
        uv.x *= uResolution.x / uResolution.y;
        
        float time = uTime * 0.254; 
        float h = getHeight(uv, time, uScroll, uRandomSeed);
        float eps = 0.01;
        float hx1 = getHeight(uv + vec2(eps, 0.0), time, uScroll, uRandomSeed);
        float hx2 = getHeight(uv - vec2(eps, 0.0), time, uScroll, uRandomSeed);
        float hy1 = getHeight(uv + vec2(0.0, eps), time, uScroll, uRandomSeed);
        float hy2 = getHeight(uv - vec2(0.0, eps), time, uScroll, uRandomSeed);
        
        vec3 normal = normalize(vec3(hx2 - hx1, hy2 - hy1, 0.03));
        vec3 lightDir = normalize(vec3(uLightX, uLightY, 0.4));
        float light = dot(normal, lightDir) * 0.5 + 0.5;
        
        vec3 color = mix(uColorAmbient, uColorDeep, smoothstep(0.0, uStop1 + 0.001, light));
        color = mix(color, uColorMid, smoothstep(uStop1, uStop2 + 0.001, light));
        color = mix(color, uColorSoft, smoothstep(uStop2, uStop3 + 0.001, light));
        color = mix(color, uColorHigh, smoothstep(uStop3, uStop4 + 0.001, light));
        color = mix(color, uColorSpec, smoothstep(uStop4, 1.001, light));
        
        color = (color - 0.5) * uContrast + 0.5 + uBrightness;
        color = clamp(color, 0.0, 1.0);
        vec3 hsl = rgb2hsl(color);
        hsl.x = mod(hsl.x + uHueShift, 1.0);
        hsl.y = clamp(hsl.y * uSaturation, 0.0, 1.0);
        color = hsl2rgb(hsl);
        
        float p = clamp(uScroll, 0.0, 1.0);
        float easedScroll = 1.0 - pow(max(1.0 - p, 0.0), uWaveCurve);
        
        float wavePos = easedScroll * uWaveSpeed - 0.2;
        float waveOffset = h * 0.4 + sin(uv.x * 4.0 + time) * 0.05;
        float dist = wavePos - (vUv.y + waveOffset);
        
        float whiteMask = smoothstep(0.0, max(uMaskSmooth, 0.01), dist);
        float waveCrest = smoothstep(-0.05, max(uCrestSize, 0.01), dist) * smoothstep(uCrestSize * 2.0, 0.05, dist);
        
        vec3 finalColor = mix(color, uWaveColor, whiteMask);
        finalColor += uCrestColor * waveCrest * 0.6;
        float subtleBump = (light - 0.5) * 0.03 * whiteMask;
        finalColor += subtleBump;

        vec2 grainUv = floor(vUv * uResolution * uGrainScale);
        float grainTime = uTime * uGrainSpeed;
        float dither = fract(sin(dot(grainUv, vec2(12.9898, 78.233)) + grainTime) * 43758.5453);
        float baseDither = (fract(sin(dot(vUv * uResolution, vec2(12.9898, 78.233)))) - 0.5) * (2.0 / 255.0);
        finalColor += baseDither + (dither - 0.5) * uGrainIntensity;

        gl_FragColor = vec4(clamp(finalColor, 0.0, 1.0), 1.0);
    }
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sectionId = "{{ section.id }}";
      const wrapper = document.querySelector('.glacier-wrapper-' + sectionId);
      const globalBgContainer = document.getElementById('glacier-global-bg-' + sectionId);
      const mediaLayer = document.getElementById('media-layer-' + sectionId);
      const mediaContent = document.getElementById('media-content-' + sectionId);
      const bfcmCarousel = document.getElementById('bfcm-carousel-' + sectionId);
      const loadingCover = document.getElementById('home-loading-cover-' + sectionId);
      const loadingLogo = loadingCover?.querySelector('[data-home-loading-logo]');
      let bfcmCarouselTimer = null;
      let bfcmCarouselIndex = 0;
      let bfcmCarouselKey = '';
      let loadingCoverTimer = null;
      let activeMediaElement = null;
      let activeMediaUrl = '';
      let mediaSwitchToken = 0;
      let syncGlacierAnimationState = () => {};
      const videoPool = new Map();
      const imagePool = new Map();
      const mediaReadyTimeout = 1800;
      const fallbackPosterByUrl = new Map([
        ["{{ 'home-bfcm-video.mp4' | asset_url }}", "{{ 'home-bfcm-1.webp' | asset_url }}"]
      ]);

      if (globalBgContainer && globalBgContainer.parentNode !== document.body) {
          const mainContent = document.getElementById('MainContent') || document.querySelector('main') || document.body;
          mainContent.insertBefore(globalBgContainer, mainContent.firstChild);
      }

      if (loadingCover && loadingCover.parentNode !== document.body) {
        document.body.appendChild(loadingCover);
      }

      const wait = (ms) => new Promise(resolve => window.setTimeout(resolve, ms));

      const createMediaElement = (url, type) => {
        if (type === 'video') {
          if (videoPool.has(url)) return videoPool.get(url);
          const video = document.createElement('video');
          video.className = 'glacier-media-item-' + sectionId;
          video.muted = true;
          video.loop = true;
          video.playsInline = true;
          video.preload = 'none';
          video.setAttribute('aria-hidden', 'true');
          video.src = url;
          mediaContent.appendChild(video);
          videoPool.set(url, video);
          return video;
        }

        if (imagePool.has(url)) return imagePool.get(url);
        const image = document.createElement('img');
        image.className = 'glacier-media-item-' + sectionId;
        image.alt = '';
        image.decoding = 'async';
        image.src = url;
        mediaContent.appendChild(image);
        imagePool.set(url, image);
        return image;
      };

      const waitForMediaReady = (element, type, timeout = mediaReadyTimeout) => new Promise(resolve => {
        if (!element) {
          resolve(false);
          return;
        }

        if (type === 'image') {
          if (element.complete && element.naturalWidth > 0) {
            resolve(true);
            return;
          }
        } else if (element.readyState >= 2) {
          resolve(true);
          return;
        }

        let settled = false;
        let timeoutId = null;
        const cleanup = () => {
          element.removeEventListener('load', handleReady);
          element.removeEventListener('loadeddata', handleReady);
          element.removeEventListener('canplay', handleReady);
          element.removeEventListener('error', handleError);
          if (timeoutId) clearTimeout(timeoutId);
        };
        const finish = (ready) => {
          if (settled) return;
          settled = true;
          cleanup();
          resolve(ready);
        };
        const handleReady = () => finish(true);
        const handleError = () => finish(false);

        if (type === 'image') {
          element.addEventListener('load', handleReady, { once: true });
        } else {
          element.addEventListener('loadeddata', handleReady, { once: true });
          element.addEventListener('canplay', handleReady, { once: true });
        }
        element.addEventListener('error', handleError, { once: true });
        timeoutId = window.setTimeout(() => {
          const ready = type === 'image'
            ? element.complete && element.naturalWidth > 0
            : element.readyState >= 2;
          finish(ready);
        }, timeout);
      });

      const playMediaElement = (element, restart = false) => {
        if (!(element instanceof HTMLVideoElement)) return Promise.resolve(true);
        if (restart) {
          try { element.currentTime = 0; } catch (error) {}
        }
        const playPromise = element.play();
        if (playPromise && typeof playPromise.catch === 'function') {
          return playPromise.then(() => true).catch(() => {
            return wait(300).then(() => {
              const retryPromise = element.play();
              if (retryPromise && typeof retryPromise.catch === 'function') {
                return retryPromise.then(() => true).catch(() => false);
              }
              return true;
            });
          });
        }
        return Promise.resolve(true);
      };

      const splitLoadingLogo = () => {
        if (!loadingLogo || loadingLogo.dataset.split === 'true') return;
        const text = loadingLogo.textContent || '';
        const visibleChars = Array.from(text).filter(char => char.trim()).length;
        const step = visibleChars > 1 ? (600 - 200) / (visibleChars - 1) : 0;
        let charIndex = 0;
        loadingLogo.innerHTML = '';

        text.split(/(\s+)/).forEach(part => {
          if (!part) return;
          if (/^\s+$/.test(part)) {
            loadingLogo.appendChild(document.createTextNode(part));
            return;
          }

          const word = document.createElement('span');
          word.className = 'home-loading-word-' + sectionId;
          Array.from(part).forEach(char => {
            const span = document.createElement('span');
            const targetWeight = Math.round(600 - charIndex * step);
            span.className = 'home-loading-char-' + sectionId;
            span.textContent = char;
            span.style.setProperty('--char-index', charIndex);
            span.style.setProperty('--target-weight', targetWeight);
            word.appendChild(span);
            charIndex++;
          });
          loadingLogo.appendChild(word);
        });

        loadingLogo.dataset.split = 'true';
      };

      const startHomeLoadingCover = () => {
        if (!loadingCover) return;

        splitLoadingLogo();
        document.body.classList.add('home-loading-active-' + sectionId);

        wait(1600).then(() => {
          loadingCover.classList.add('is-leaving');
          document.body.classList.remove('home-loading-active-' + sectionId);
          loadingCoverTimer = window.setTimeout(() => {
            loadingCover.remove();
          }, 820);
        });
      };

      startHomeLoadingCover();

      function initGlacierWebGL() {
        if (typeof THREE === 'undefined') {
            setTimeout(initGlacierWebGL, 50);
            return;
        }

        const canvas = document.getElementById('canvas-' + sectionId);
        if (!canvas) return;
        
        const scene = new THREE.Scene();
        const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
        const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: false, alpha: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
        
        const shaderMaterial = new THREE.ShaderMaterial({
            vertexShader: document.getElementById('vs-' + sectionId).textContent,
            fragmentShader: document.getElementById('fs-' + sectionId).textContent,
            uniforms: {
                uTime: { value: 0 },
                uResolution: { value: new THREE.Vector2() },
                uScroll: { value: 0 },
                uRandomSeed: { value: Math.random() * 100 },
                uContrast: { value: {{ section.settings.fluid_contrast | default: 1.0 }} },
                uBrightness: { value: {{ section.settings.fluid_brightness | default: 0.0 }} },
                uHueShift: { value: {{ section.settings.fluid_hue | default: 0 }} / 360.0 },
                uSaturation: { value: {{ section.settings.fluid_saturation | default: 1.0 }} },
                uThemeSpeed: { value: 0.4 },
                uThemeDetail: { value: 1.3 },
                uWaveFreq: { value: 1.5 },
                uDistortion: { value: 5.0 },
                uMaskSmooth: { value: 0.15 },
                uCrestSize: { value: 0.1 },
                uWaveSpeed: { value: {{ section.settings.wave_speed | default: 2.8 }} },
                uWaveCurve: { value: {{ section.settings.wave_curve | default: 2.0 }} },
                uColorAmbient: { value: new THREE.Color("#ffffff") },
                uColorDeep: { value: new THREE.Color("#f2f2f2") },
                uColorMid: { value: new THREE.Color("#fafafa") },
                uColorSoft: { value: new THREE.Color("#ffffff") },
                uColorHigh: { value: new THREE.Color("#f5f5f5") },
                uColorSpec: { value: new THREE.Color("#c7c7c7") },
                uStop1: { value: 0.24 },
                uStop2: { value: 0.44 },
                uStop3: { value: 0.52 },
                uStop4: { value: 0.83 },
                uWaveColor: { value: new THREE.Color("#ffffff") },
                uCrestColor: { value: new THREE.Color("#fafcff") },
                uLightX: { value: -0.6 },
                uLightY: { value: 0.5 },
                uGrainIntensity: { value: 0.0 },
                uGrainScale: { value: 0.1 },
                uGrainSpeed: { value: 0.0 }
            }
        });
        
        scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), shaderMaterial));
        
        const resize = () => {
            const w = window.innerWidth, h = window.innerHeight; 
            renderer.setSize(w, h);
            shaderMaterial.uniforms.uResolution.value.set(w, h);
        };
        window.addEventListener('resize', resize);
        resize();
        
        const clock = new THREE.Clock();
        let customTime = 0;
        
        let targetSpeedOffset = 0; 
        let currentSpeedOffset = 0;
        
        let targetScroll = 0; 
        let currentScroll = 0;

        let lastMouseX = 0; let lastMouseY = 0;
        let lastMouseTime = performance.now();
        
        window.addEventListener('mousemove', (e) => {
            const now = performance.now(); 
            const dt = now - lastMouseTime;
            if (dt > 0) {
                const dx = e.clientX - lastMouseX; 
                const dy = e.clientY - lastMouseY;
                const speed = Math.sqrt(dx * dx + dy * dy) / dt; 
                if (speed > 0.01) { 
                    const configSlowBoost = {{ section.settings.slow_mouse_boost | default: 15.0 }};
                    let boost = configSlowBoost / (1.0 + speed * 2.0); 
                    targetSpeedOffset = Math.min(targetSpeedOffset + boost * 0.01, configSlowBoost);
                }
            }
            lastMouseX = e.clientX; 
            lastMouseY = e.clientY; 
            lastMouseTime = now;
        });

        let animationFrameId = null;
        const shouldRunGlacierAnimation = () => !mediaLayer.classList.contains('active') && !document.hidden;
        const animate = () => {
            animationFrameId = null;
            if (!shouldRunGlacierAnimation()) return;

            if (wrapper) {
                const rect = wrapper.getBoundingClientRect();
                let scrollPercent = 0;
                if (rect.top <= 0) {
                    scrollPercent = Math.abs(rect.top) / window.innerHeight;
                }
                targetScroll = Math.max(0, scrollPercent);
            }

            // 🌟 將整數 1~20 縮放為 0.01~0.20，繞過 Shopify 小數點限制
            const scrollInertia = {{ section.settings.wave_scroll_inertia | default: 6 }} / 100.0;
            currentScroll += (targetScroll - currentScroll) * scrollInertia;

            shaderMaterial.uniforms.uScroll.value = currentScroll;
            
            const friction = {{ section.settings.mouse_inertia | default: 96 }} / 100.0;
            const delta = clock.getDelta(); 
            const elapsedTime = clock.getElapsedTime();
            
            targetSpeedOffset *= friction; 
            currentSpeedOffset += (targetSpeedOffset - currentSpeedOffset) * 0.05;
            
            const configBaseSpeed = {{ section.settings.base_fluid_speed | default: 2.5 }};
            const rhythm = Math.sin(elapsedTime * 1.8) * 0.9;
            customTime += delta * (configBaseSpeed + rhythm + currentSpeedOffset);
            
            shaderMaterial.uniforms.uWaveSpeed.value = {{ section.settings.wave_speed | default: 2.8 }};
            shaderMaterial.uniforms.uWaveCurve.value = {{ section.settings.wave_curve | default: 2.0 }};

            shaderMaterial.uniforms.uTime.value = customTime;
            renderer.render(scene, camera);
            animationFrameId = requestAnimationFrame(animate);
        };
        syncGlacierAnimationState = () => {
            if (!shouldRunGlacierAnimation()) {
                if (animationFrameId !== null) {
                    cancelAnimationFrame(animationFrameId);
                    animationFrameId = null;
                }
                return;
            }
            if (animationFrameId === null) {
                clock.getDelta();
                animationFrameId = requestAnimationFrame(animate);
            }
        };
        syncGlacierAnimationState();
	      }

      initGlacierWebGL();

      const replayActiveVideo = () => {
        if (!(activeMediaElement instanceof HTMLVideoElement)) return;
        playMediaElement(activeMediaElement, true);
      };

      const deactivateMediaElement = (element) => {
        if (!element) return;
        element.classList.remove('is-active');
        if (element instanceof HTMLVideoElement) {
          window.setTimeout(() => {
            if (!element.classList.contains('is-active')) element.pause();
          }, 440);
        }
      };

      const activateMediaElement = (element, url) => {
        if (!element) return;
        if (activeMediaElement && activeMediaElement !== element) {
          deactivateMediaElement(activeMediaElement);
        }
        activeMediaElement = element;
        activeMediaUrl = url;
        mediaContent.setAttribute('data-active-url', url);
	        element.classList.add('is-active');
	        globalBgContainer.classList.add('is-media-mode-' + sectionId);
	        mediaLayer.classList.add('active');
	        syncGlacierAnimationState();
	      };

      const clearActiveMedia = () => {
        if (activeMediaElement) deactivateMediaElement(activeMediaElement);
        activeMediaElement = null;
        activeMediaUrl = '';
	        mediaContent.setAttribute('data-active-url', '');
	        mediaLayer.classList.remove('active');
	        globalBgContainer.classList.remove('is-media-mode-' + sectionId);
	        syncGlacierAnimationState();
	      };

      const fallbackToPosterOrWave = async (url, token) => {
        const posterUrl = fallbackPosterByUrl.get(url);
        if (!posterUrl) {
          clearActiveMedia();
          return;
        }

        const poster = createMediaElement(posterUrl, 'image');
        const posterReady = await waitForMediaReady(poster, 'image', 900);
        if (token !== mediaSwitchToken) return;
        if (!posterReady) {
          clearActiveMedia();
          return;
        }
        activateMediaElement(poster, posterUrl);
      };

      const stopBfcmCarousel = () => {
        if (bfcmCarouselTimer) {
          clearInterval(bfcmCarouselTimer);
          bfcmCarouselTimer = null;
        }
        bfcmCarouselIndex = 0;
        if (!bfcmCarousel) return;
        bfcmCarousel.classList.remove('active');
      };

      const startBfcmCarousel = (galleryUrls) => {
        const urls = Array.isArray(galleryUrls) ? galleryUrls.filter(Boolean) : [];
        stopBfcmCarousel();
        if (!bfcmCarousel || !urls.length) return;

        const nextKey = urls.join('|');
        if (bfcmCarouselKey !== nextKey) {
          bfcmCarousel.innerHTML = '';
          urls.forEach((src, index) => {
            const image = document.createElement('img');
            image.src = src;
            image.alt = '';
            image.decoding = 'async';
            image.loading = index === 0 ? 'eager' : 'lazy';
            image.className = index === 0 ? 'is-active' : '';
            bfcmCarousel.appendChild(image);
          });
          bfcmCarouselKey = nextKey;
        } else {
          Array.from(bfcmCarousel.querySelectorAll('img')).forEach((image, index) => {
            image.classList.toggle('is-active', index === 0);
          });
        }

        bfcmCarousel.classList.add('active');
        if (urls.length <= 1) return;
        bfcmCarouselTimer = window.setInterval(() => {
          const slides = Array.from(bfcmCarousel.querySelectorAll('img'));
          if (!slides.length) return;
          slides[bfcmCarouselIndex]?.classList.remove('is-active');
          bfcmCarouselIndex = (bfcmCarouselIndex + 1) % slides.length;
          slides[bfcmCarouselIndex]?.classList.add('is-active');
        }, 3300);
      };

      const setGlacierMedia = async (url, type, toggleIfSame = false, restartIfSame = false, galleryUrls = []) => {
        const switchToken = ++mediaSwitchToken;

        if (!url || type === "none") {
          stopBfcmCarousel();
          clearActiveMedia();
          return;
        }
        if (galleryUrls.length) {
          startBfcmCarousel(galleryUrls);
        } else {
          stopBfcmCarousel();
        }
        if (mediaLayer.classList.contains('active') && activeMediaUrl === url) {
          if (restartIfSame && type === 'video') replayActiveVideo();
          return;
        }

        const mediaElement = createMediaElement(url, type);
        if (type === 'video') {
          mediaElement.preload = 'auto';
          if (mediaElement.readyState < 2) {
            try { mediaElement.load(); } catch (error) {}
          }
        }
        const ready = await waitForMediaReady(mediaElement, type);
        if (switchToken !== mediaSwitchToken) return;

        if (!ready) {
          await fallbackToPosterOrWave(url, switchToken);
          return;
        }

        const canPlay = type === 'video' ? await playMediaElement(mediaElement, restartIfSame) : true;
        if (switchToken !== mediaSwitchToken) return;

        if (!canPlay) {
          await fallbackToPosterOrWave(url, switchToken);
          return;
        }

        activateMediaElement(mediaElement, url);
      };

      const handleGlacierActivateMedia = (e) => {
        const sourceWrapper = e.detail?.wrapper;
        if (sourceWrapper && sourceWrapper.closest('.glacier-wrapper-' + sectionId) !== wrapper) return;
        setGlacierMedia(e.detail?.url, e.detail?.type, false, Boolean(e.detail?.restart), e.detail?.galleryUrls || []);
      };

      window.addEventListener('glacier:activate-media', handleGlacierActivateMedia);
      document.addEventListener('visibilitychange', syncGlacierAnimationState);

      const handleSectionUnload = (e) => {
        if (e.detail.sectionId === sectionId) {
          if (globalBgContainer && globalBgContainer.parentNode) {
            stopBfcmCarousel();
            if (loadingCoverTimer) clearTimeout(loadingCoverTimer);
            window.removeEventListener('glacier:activate-media', handleGlacierActivateMedia);
            document.removeEventListener('visibilitychange', syncGlacierAnimationState);
            document.removeEventListener('shopify:section:unload', handleSectionUnload);
            videoPool.forEach(video => {
              try {
                video.pause();
                video.removeAttribute('src');
                video.load();
              } catch (error) {}
              video.remove();
            });
            imagePool.forEach(image => image.remove());
            videoPool.clear();
            imagePool.clear();
            loadingCover?.remove();
            document.body.classList.remove('home-loading-active-' + sectionId);
            globalBgContainer.parentNode.removeChild(globalBgContainer);
          }
        }
      };

      document.addEventListener('shopify:section:unload', handleSectionUnload);
    });
  </script>
{%- endif -%}

<div class="glacier-wrapper-{{ section.id }}">
  <div class="glacier-content-{{ section.id }}">
    {% content_for 'blocks' %}
  </div>
</div>

