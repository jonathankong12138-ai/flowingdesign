      "min": 0, "max": 200, "step": 5, "unit": "px",
      "label": "上边距 (Top)", "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 200, "step": 5, "unit": "px",
      "label": "下边距 (Bottom)", "default": 80
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "min": 0, "max": 150, "step": 5, "unit": "px",
      "label": "左内边距 (Left)", "default": 80
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "min": 0, "max": 150, "step": 5, "unit": "px",
      "label": "右内边距 (Right)", "default": 80
    },
    {
      "type": "range",
      "id": "item_spacing_desktop",
      "min": 0, "max": 300, "step": 5, "unit": "px",
      "label": "所有项目与媒体的间距", "default": 160
    },
    {
      "type": "header",
      "content": "📱 手机端间距控制 (px)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 150, "step": 5, "unit": "px",
      "label": "上边距 (Top)", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 150, "step": 5, "unit": "px",
      "label": "下边距 (Bottom)", "default": 60
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0, "max": 80, "step": 2, "unit": "px",
      "label": "左内边距 (Left)", "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0, "max": 80, "step": 2, "unit": "px",
      "label": "右内边距 (Right)", "default": 20
