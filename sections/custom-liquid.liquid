<script>
  function initFDWorks() {
    const sectionId = '{{ section_id }}';
    const wrapper = document.getElementById('fd-' + sectionId);
    if (!wrapper) return;

    const shopifySection = wrapper.closest('.shopify-section');
    if (shopifySection) {
        shopifySection.style.position = 'relative';
        shopifySection.style.zIndex = '50';
    }

    const initHeatmapWave = () => {
      if (wrapper.dataset.heatmapReady === 'true') return;
      const canvas = wrapper.querySelector('[data-fd-heatmap-canvas]');
      const hoverTargets = wrapper.querySelectorAll('[data-heatmap-hover="true"]');
      if (!canvas || !hoverTargets.length || typeof THREE === 'undefined') return;
      wrapper.dataset.heatmapReady = 'true';

      let renderer;
      try {
        renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      } catch (error) {
        wrapper.dataset.heatmapReady = 'false';
        console.warn('FD heatmap wave failed to initialize:', error);
        return;
      }

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));

      const vertexShader = `
        varying vec2 vUv;
        void main() { vUv = uv; gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }
      `;
      const fragmentShader = `
	        uniform float uTime; uniform vec2 uResolution; uniform float uScroll; uniform float uRandomSeed; uniform float uHeatmapStyle;
        varying vec2 vUv;
        mat2 rotate2d(float angle){ return mat2(cos(angle), -sin(angle), sin(angle), cos(angle)); }
        vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }
        float snoise(vec2 v){
          const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
          vec2 i = floor(v + dot(v, C.yy)); vec2 x0 = v - i + dot(i, C.xx);
          vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
          vec4 x12 = x0.xyxy + C.xxzz; x12.xy -= i1; i = mod(i, 289.0);
          vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
          vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
          m = m*m; m = m*m;
          vec3 x = 2.0 * fract(p * C.www) - 1.0; vec3 h = abs(x) - 0.5;
          vec3 ox = floor(x + 0.5); vec3 a0 = x - ox;
          m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
          vec3 g; g.x = a0.x * x0.x + h.x * x0.y; g.yz = a0.yz * x12.xz + h.yz * x12.yw;
          return 130.0 * dot(m, g);
        }
        vec3 rgb2hsl(vec3 c){
          float maxC = max(c.r, max(c.g, c.b)); float minC = min(c.r, min(c.g, c.b)); float h, s, l = (maxC + minC) / 2.0;
          if(maxC == minC){ h = s = 0.0; } else{ float d = maxC - minC; s = l > 0.5 ? d / (2.0 - maxC - minC) : d / (maxC + minC);
            if(maxC == c.r) h = (c.g - c.b) / d + (c.g < c.b ? 6.0 : 0.0); else if(maxC == c.g) h = (c.b - c.r) / d + 2.0; else h = (c.r - c.g) / d + 4.0; h /= 6.0;
          } return vec3(h, s, l);
        }
        float hue2rgb(float p, float q, float t){
          if(t < 0.0) t += 1.0; if(t > 1.0) t -= 1.0; if(t < 1.0/6.0) return p + (q - p) * 6.0 * t;
          if(t < 1.0/2.0) return q; if(t < 2.0/3.0) return p + (q - p) * (2.0/3.0 - t) * 6.0; return p;
        }
        vec3 hsl2rgb(vec3 c){
          vec3 rgb; if(c.y == 0.0){ rgb = vec3(c.z); } else{
            float q = c.z < 0.5 ? c.z * (1.0 + c.y) : c.z + c.y - c.z * c.y; float p = 2.0 * c.z - q;
            rgb.r = hue2rgb(p, q, c.x + 1.0/3.0); rgb.g = hue2rgb(p, q, c.x); rgb.b = hue2rgb(p, q, c.x - 1.0/3.0);
          } return rgb;
        }
        float getDefaultHeight(vec2 uv, float time, float scroll, float seed) {
          vec2 seedOffset = vec2(seed * 10.3, seed * 4.2);
          vec2 baseUV = uv + seedOffset + vec2(0.0, scroll * 0.2);
          float flowTime = time * 0.8 + scroll * 0.5;
          vec2 rotUV = rotate2d(-0.5) * baseUV;
          vec2 distortion = vec2(0.0);
          distortion.x = snoise(rotUV * 0.5 + vec2(flowTime * 0.15, flowTime * 0.1));
          distortion.y = snoise(rotUV * 0.5 - vec2(flowTime * 0.1, flowTime * 0.1));
          float detail = snoise(rotUV * 0.975 + distortion + flowTime * 0.1) * 0.065;
          float wave = sin(rotUV.y * 0.6 + distortion.x * 1.7 + flowTime);
          return pow(max(wave * 0.5 + 0.5, 0.0), 0.8) + detail;
        }
	        float getBfcmHeight(vec2 uv, float time, float scroll, float seed) {
	          vec2 seedOffset = vec2(seed * 10.3, seed * 4.2);
	          vec2 baseUV = uv + seedOffset + vec2(0.0, scroll * 0.2);
          float flowTime = time * 0.5 + scroll * 0.5;
          vec2 rotUV = rotate2d(-0.5) * baseUV;
          vec2 distortion = vec2(0.0);
          distortion.x = snoise(rotUV * 0.5 + vec2(flowTime * 0.15, flowTime * 0.1));
          distortion.y = snoise(rotUV * 0.5 - vec2(flowTime * 0.1, flowTime * 0.1));
          float detail = snoise(rotUV * 0.3 + distortion + flowTime * 0.1) * 0.02;
	          float wave = sin(rotUV.y * 1.6 + distortion.x * 3.3 + flowTime);
	          return pow(max(wave * 0.5 + 0.5, 0.0), 0.8) + detail;
	        }
	        float getGtmHeight(vec2 uv, float time, float scroll, float seed) {
	          vec2 seedOffset = vec2(seed * 10.3, seed * 4.2);
	          vec2 baseUV = uv + seedOffset + vec2(0.0, scroll * 0.2);
	          float flowTime = time * 0.9 + scroll * 0.5;
	          vec2 rotUV = rotate2d(-0.5) * baseUV;
	          vec2 distortion = vec2(0.0);
	          distortion.x = snoise(rotUV * 0.5 + vec2(flowTime * 0.15, flowTime * 0.1));
	          distortion.y = snoise(rotUV * 0.5 - vec2(flowTime * 0.1, flowTime * 0.1));
	          float detail = snoise(rotUV * 1.125 + distortion + flowTime * 0.1) * 0.075;
	          float wave = sin(rotUV.y * 5.0 + distortion.x * 3.1 + flowTime);
	          return pow(max(wave * 0.5 + 0.5, 0.0), 0.8) + detail;
	        }
	        float getHeight(vec2 uv, float time, float scroll, float seed) {
	          if (uHeatmapStyle > 1.5) return getGtmHeight(uv, time, scroll, seed);
	          if (uHeatmapStyle > 0.5) return getBfcmHeight(uv, time, scroll, seed);
	          return getDefaultHeight(uv, time, scroll, seed);
	        }
        float deepHaloMask(float lightValue, float rangeValue, float featherValue) {
          float stopGap = max(0.06 - 0.59, 0.001);
          float halfWidth = stopGap * mix(0.04, 0.50, clamp(rangeValue, 0.0, 1.0));
          float feather = max(featherValue * halfWidth * 1.4, 0.001);
          float innerEdge = 0.59 - halfWidth;
          float outerEdge = 0.59 + halfWidth;
          float innerFade = smoothstep(innerEdge - feather, innerEdge, lightValue);
          float outerFade = 1.0 - smoothstep(outerEdge, outerEdge + feather, lightValue);
          return innerFade * outerFade;
        }
        float deepHaloShape(float flowValue, float featherValue) {
          float feather = clamp(featherValue, 0.01, 0.95);
          return smoothstep(1.0 - feather, 1.0, flowValue);
        }
	        void main() {
	          vec2 uv = vUv;
	          uv.x *= uResolution.x / uResolution.y;
	          float time = uTime * 0.254;
	          float h = getHeight(uv, time, uScroll, uRandomSeed);
	          float eps = 0.01;
	          float hx1 = getHeight(uv + vec2(eps, 0.0), time, uScroll, uRandomSeed);
	          float hx2 = getHeight(uv - vec2(eps, 0.0), time, uScroll, uRandomSeed);
	          float hy1 = getHeight(uv + vec2(0.0, eps), time, uScroll, uRandomSeed);
	          float hy2 = getHeight(uv - vec2(0.0, eps), time, uScroll, uRandomSeed);
	          vec3 normal = normalize(vec3(hx2 - hx1, hy2 - hy1, 0.03));
	          vec3 lightDir = uHeatmapStyle > 1.5 ? vec3(-0.6, 0.5, 0.4) : (uHeatmapStyle > 0.5 ? vec3(-0.4, 0.6, 0.4) : vec3(-0.5, 0.5, 0.4));
	          float light = dot(normal, normalize(lightDir)) * 0.5 + 0.5;

          vec3 color;
          if (uHeatmapStyle > 1.5) {
            color = mix(vec3(1.0), vec3(0.867, 0.812, 0.733), smoothstep(0.0, 1.0, light));
            color = mix(color, vec3(0.729, 0.686, 0.612), smoothstep(0.24, 0.59, light));
            color = mix(color, vec3(1.0), smoothstep(0.59, 1.0, light));
            float deepHaloBand1 = smoothstep(0.0, 0.52, light) * (1.0 - smoothstep(0.52, 0.91, light));
            float deepHaloBand2 = smoothstep(0.0, 1.0, light);
            float deepFlow1 = snoise((uv / 3.9) * 3.0 + vec2(time * 0.08, -time * 0.03)) * 0.5 + 0.5;
            float deepFlow2 = snoise((uv / 6.0) * 3.0 - vec2(time * 0.05, time * 0.06) + vec2(12.47)) * 0.5 + 0.5;
            vec3 deepHalo = vec3(1.0, 0.584, 0.0) * deepHaloBand1 * deepHaloShape(deepFlow1, 0.77) * 0.98;
            deepHalo += vec3(1.0, 0.635, 0.0) * deepHaloBand2 * deepHaloShape(deepFlow2, 0.4) * 0.97;
            color = 1.0 - (1.0 - color) * (1.0 - clamp(deepHalo, 0.0, 1.0));
            color = (color - 0.5) * 1.25 + 0.45;
            color = clamp(color - 0.05, 0.0, 1.0);
          } else if (uHeatmapStyle > 0.5) {
            color = mix(vec3(0.0), vec3(1.0, 0.647, 0.361), smoothstep(0.0, 0.381, light));
            color = mix(color, vec3(0.439, 0.0, 0.0), smoothstep(0.38, 1.001, light));
            color = mix(color, vec3(0.2, 0.0, 0.0), smoothstep(1.0, 1.001, light));
            color = mix(color, vec3(0.0), smoothstep(1.0, 1.001, light));
            color = mix(color, vec3(0.0), smoothstep(1.0, 1.001, light));
            color = (color - 0.5) * 1.45 + 0.5 - 0.15;
            color = clamp(color, 0.0, 1.0);
            vec3 hsl = rgb2hsl(color);
            hsl.y = clamp(hsl.y * 1.3, 0.0, 1.0);
            color = hsl2rgb(hsl);
          } else {
            color = mix(vec3(0.792, 0.341, 1.0), vec3(0.078, 0.463, 1.0), smoothstep(0.0, 0.591, light));
            color = mix(color, vec3(1.0, 0.502, 0.502), smoothstep(0.59, 0.061, light));
            color = mix(color, vec3(1.0), smoothstep(0.06, 1.001, light));
            color = mix(color, vec3(1.0), smoothstep(1.0, 1.001, light));
            color = mix(color, vec3(1.0), smoothstep(1.0, 1.001, light));
            float deepHaloBand1 = deepHaloMask(light, 1.0, 0.95);
            float deepHaloBand2 = deepHaloMask(light, 0.0, 0.29);
            float deepFlow1 = snoise((uv / 6.0) * 3.0 + vec2(time * 0.08, -time * 0.03)) * 0.5 + 0.5;
            float deepFlow2 = snoise((uv / 1.2) * 3.0 - vec2(time * 0.05, time * 0.06) + vec2(12.47)) * 0.5 + 0.5;
            vec3 deepHalo = vec3(0.0, 0.898, 0.659) * deepHaloBand1 * deepHaloShape(deepFlow1, 0.95) * 0.77;
            deepHalo += vec3(1.0, 0.506, 0.239) * deepHaloBand2 * deepHaloShape(deepFlow2, 0.29) * 1.5;
            color = 1.0 - (1.0 - color) * (1.0 - clamp(deepHalo, 0.0, 1.0));
            color = (color - 0.5) * 1.5 + 0.35;
            color = clamp(color, 0.0, 1.0);
            vec3 hsl = rgb2hsl(color);
            hsl.y = clamp(hsl.y, 0.0, 1.0);
            color = hsl2rgb(hsl);
          }

	          float p = clamp(uScroll, 0.0, 1.0);
	          float easedScroll = 1.0 - pow(max(1.0 - p, 0.0), 2.0);
	          float wavePos = easedScroll * 2.8 - 0.2;
	          float waveOffset = h * 0.4 + sin(uv.x * 4.0 + time) * 0.05;
	          float dist = wavePos - (vUv.y + waveOffset);
          vec3 finalColor;
          if (uHeatmapStyle > 1.5) {
            float whiteMask = smoothstep(0.0, 0.15, dist);
            float crest = smoothstep(-0.05, 0.10, dist) * smoothstep(0.20, 0.05, dist);
            finalColor = mix(color, vec3(1.0), whiteMask);
            finalColor += vec3(0.980, 0.988, 1.0) * crest * 0.6;
            finalColor += (light - 0.5) * 0.03 * whiteMask;
            vec2 grainUv = floor(vUv * uResolution);
            float dither = fract(sin(dot(grainUv, vec2(12.9898, 78.233)) + uTime * 2.0) * 43758.5453);
            float baseDither = (fract(sin(dot(vUv * uResolution, vec2(12.9898, 78.233)))) - 0.5) * (2.0 / 255.0);
            finalColor += baseDither + (dither - 0.5) * 0.03;
          } else if (uHeatmapStyle > 0.5) {
            float coloredWave = smoothstep(0.0, 0.15, dist);
            float crest = smoothstep(-0.05, 0.25, dist) * smoothstep(0.5, 0.05, dist);
            finalColor = mix(color, vec3(0.502, 0.0, 0.0), coloredWave * 0.28);
            finalColor += vec3(1.0, 0.502, 0.0) * crest * 0.34;
            finalColor += (light - 0.5) * 0.03 * coloredWave;
            vec2 grainUv = floor(vUv * uResolution);
            float dither = fract(sin(dot(grainUv, vec2(12.9898, 78.233)) + uTime * 2.0) * 43758.5453);
            float baseDither = (fract(sin(dot(vUv * uResolution, vec2(12.9898, 78.233)))) - 0.5) * (2.0 / 255.0);
            finalColor += baseDither + (dither - 0.5) * 0.03;
          } else {
            float whiteMask = smoothstep(0.0, 0.15, dist);
            float crest = smoothstep(-0.08, 0.16, dist) * smoothstep(0.32, 0.04, dist);
            finalColor = mix(color, vec3(1.0), whiteMask);
            finalColor += vec3(1.0, 0.878, 0.961) * crest * 0.28;
            finalColor += (light - 0.5) * 0.03 * whiteMask;
          }

	          float revealTop = clamp(wavePos, 0.0, 0.52);
	          float revealStrength = smoothstep(0.02, 0.10, p);
	          float revealAlpha = (1.0 - smoothstep(revealTop - 0.30, revealTop + 0.24, vUv.y)) * revealStrength;
	          revealAlpha *= smoothstep(0.0, 0.18, vUv.y);
	          gl_FragColor = vec4(clamp(finalColor, 0.0, 1.0), revealAlpha);
	        }
      `;

      const uniforms = {
	        uTime: { value: 0 },
	        uResolution: { value: new THREE.Vector2() },
	        uScroll: { value: 0 },
	        uRandomSeed: { value: 42.0 },
	        uHeatmapStyle: { value: 0 }
	      };
      const material = new THREE.ShaderMaterial({
        vertexShader,
        fragmentShader,
        uniforms,
        transparent: true
      });
      scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material));

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        renderer.setSize(Math.max(1, rect.width), Math.max(1, rect.height));
        uniforms.uResolution.value.set(Math.max(1, rect.width), Math.max(1, rect.height));
      };
      resize();
      window.addEventListener('resize', resize);

	      let targetScroll = 0;
	      let currentScroll = 0;
	      let isHeatmapSectionVisible = true;
	      let syncHeatmapAnimationState = () => {};
	      const activeHeatmapTargets = new Set();
	      const getHeatmapStyleForTarget = (target) => {
	        if (target?.dataset.heatmapStyle) return target.dataset.heatmapStyle;
	        const activeTitle = wrapper.querySelector('.fd-project-title-item-' + sectionId + '.is-active');
	        return activeTitle?.dataset.heatmapStyle || 'default';
	      };
	      const syncHeatmapStyle = () => {
	        const activeTargets = Array.from(activeHeatmapTargets);
	        const activeTarget = activeTargets[activeTargets.length - 1];
	        const style = getHeatmapStyleForTarget(activeTarget);
	        uniforms.uHeatmapStyle.value = style === 'gtm' ? 2 : (style === 'bfcm' ? 1 : 0);
	      };
	      wrapper.fdSyncHeatmapStyle = () => {
	        syncHeatmapStyle();
	        wrapper.classList.toggle('is-heatmap-bfcm-active', uniforms.uHeatmapStyle.value > 0.5 && uniforms.uHeatmapStyle.value < 1.5 && activeHeatmapTargets.size > 0);
	        wrapper.classList.toggle('is-heatmap-gtm-active', uniforms.uHeatmapStyle.value > 1.5 && activeHeatmapTargets.size > 0);
	      };
	      let heatmapExitTimer = null;
	      const syncHeatmapClasses = () => {
	        const hasActiveTargets = activeHeatmapTargets.size > 0;
	        wrapper.classList.toggle('is-heatmap-active', hasActiveTargets);
	        wrapper.fdSyncHeatmapStyle();
	      };
	      const setActive = (active, event) => {
	        if (!event?.currentTarget) return;
	        if (active) {
	          if (heatmapExitTimer) {
	            clearTimeout(heatmapExitTimer);
	            heatmapExitTimer = null;
	          }
	          activeHeatmapTargets.add(event.currentTarget);
	        } else {
	          activeHeatmapTargets.delete(event.currentTarget);
	        }
	        syncHeatmapStyle();
	        targetScroll = activeHeatmapTargets.size > 0 ? 0.13 : 0;
	        syncHeatmapAnimationState();
	        if (activeHeatmapTargets.size === 0) {
	          wrapper.fdSyncHeatmapStyle();
	          heatmapExitTimer = window.setTimeout(() => {
	            if (activeHeatmapTargets.size > 0) return;
	            syncHeatmapClasses();
	            heatmapExitTimer = null;
	          }, 1200);
	          return;
	        }
	        syncHeatmapClasses();
	      };
      hoverTargets.forEach((target) => {
        target.addEventListener('mouseenter', setActive.bind(null, true));
        target.addEventListener('mouseleave', setActive.bind(null, false));
        target.addEventListener('focus', setActive.bind(null, true));
        target.addEventListener('blur', setActive.bind(null, false));
      });

      const clock = new THREE.Clock();
      let customTime = 0;
      let heatmapAnimationFrameId = null;
      const shouldRunHeatmapAnimation = () => {
        return isHeatmapSectionVisible && !document.hidden && (
          activeHeatmapTargets.size > 0 ||
          targetScroll > 0.001 ||
          currentScroll > 0.001
        );
      };
      const animate = () => {
        heatmapAnimationFrameId = null;
        if (!shouldRunHeatmapAnimation()) return;
        const waveEase = targetScroll > currentScroll ? 0.22 : 0.18;
        currentScroll += (targetScroll - currentScroll) * waveEase;
        uniforms.uScroll.value = currentScroll;
        const delta = Math.min(clock.getDelta(), 0.05);
        const elapsed = clock.getElapsedTime();
        customTime += delta * (2.5 + Math.sin(elapsed * 1.8) * 0.9);
        uniforms.uTime.value = customTime;
        renderer.render(scene, camera);
        if (shouldRunHeatmapAnimation()) {
          heatmapAnimationFrameId = requestAnimationFrame(animate);
        }
      };
      syncHeatmapAnimationState = () => {
        if (!shouldRunHeatmapAnimation()) {
          if (heatmapAnimationFrameId !== null) {
            cancelAnimationFrame(heatmapAnimationFrameId);
            heatmapAnimationFrameId = null;
          }
          return;
        }
        if (heatmapAnimationFrameId === null) {
          clock.getDelta();
          heatmapAnimationFrameId = requestAnimationFrame(animate);
        }
      };
      if ('IntersectionObserver' in window) {
        const heatmapVisibilityObserver = new IntersectionObserver((entries) => {
          isHeatmapSectionVisible = entries.some(entry => entry.isIntersecting);
          syncHeatmapAnimationState();
        }, { rootMargin: '160px 0px' });
        heatmapVisibilityObserver.observe(wrapper);
      }
      document.addEventListener('visibilitychange', syncHeatmapAnimationState);
      syncHeatmapAnimationState();
    };

    if (typeof THREE === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
      script.onload = initHeatmapWave;
      document.head.appendChild(script);
    } else {
      initHeatmapWave();
    }

    const syncTitlePosition = () => {
      const firstMediaCard = wrapper.querySelector('.fd-media-card-' + sectionId);
      const titleGroup = wrapper.querySelector('.fd-title-group-' + sectionId);
      if (!firstMediaCard) return;

      const firstMediaHeight = firstMediaCard.getBoundingClientRect().height;
      if (firstMediaHeight > 0) {
        wrapper.style.setProperty('--first-media-height', firstMediaHeight + 'px');
      }

      if (firstMediaHeight > 0 && titleGroup) {
        const titleHeight = titleGroup.getBoundingClientRect().height;
        const offset = Math.max((firstMediaHeight - titleHeight) / 2, 0);
        wrapper.style.setProperty('--title-start-offset', offset + 'px');
      }
    };

    const syncLeftFooterSpace = () => {
      const leftFooter = wrapper.querySelector('.fd-left-footer-' + sectionId);
      if (!leftFooter) return;

      const styles = window.getComputedStyle(leftFooter);
      const marginBottom = parseFloat(styles.marginBottom) || 0;
      const footerSpace = leftFooter.offsetHeight + marginBottom;
      if (footerSpace > 0) {
        wrapper.style.setProperty('--left-footer-space', footerSpace + 'px');
      }
    };

    let leftStickyReleaseTop = null;
    const syncLeftStickyState = () => {
      const leftSticky = wrapper.querySelector('.fd-left-sticky-' + sectionId);
      if (!leftSticky || window.innerWidth < 990 || leftSticky.classList.contains('is-released')) {
        if (leftSticky) leftSticky.classList.remove('is-stuck');
        return;
      }

      const stickyOffset = parseFloat(window.getComputedStyle(wrapper).getPropertyValue('--fd-left-sticky-offset')) || 0;
      const stickyTop = leftSticky.getBoundingClientRect().top;
      leftSticky.classList.toggle('is-stuck', stickyTop <= stickyOffset + 1);
    };

    const syncLeftStickyRelease = () => {
      const leftColumn = wrapper.querySelector('.fd-left-' + sectionId);
      const leftSticky = wrapper.querySelector('.fd-left-sticky-' + sectionId);
      const mediaCards = wrapper.querySelectorAll('.fd-media-card-' + sectionId);
      const lastMediaCard = mediaCards[mediaCards.length - 1];
      if (!leftColumn || !leftSticky || !lastMediaCard || window.innerWidth < 990) {
        if (leftSticky) leftSticky.classList.remove('is-released');
        leftStickyReleaseTop = null;
        syncLeftStickyState();
        return;
      }

      const scrollY = window.scrollY || window.pageYOffset;
      const leftColumnTop = leftColumn.getBoundingClientRect().top + scrollY;
      const lastMediaRect = lastMediaCard.getBoundingClientRect();
      const shouldRelease = lastMediaRect.top <= -(lastMediaRect.height / 3);

      if (!shouldRelease) {
        leftSticky.classList.remove('is-released');
        leftStickyReleaseTop = null;
        syncLeftStickyState();
        return;
      }

      if (leftStickyReleaseTop === null || !leftSticky.classList.contains('is-released')) {
        const stickyTop = leftSticky.getBoundingClientRect().top + scrollY;
        leftStickyReleaseTop = Math.max(stickyTop - leftColumnTop, 0);
        wrapper.style.setProperty('--fd-left-release-top', leftStickyReleaseTop + 'px');
      }

      leftSticky.classList.add('is-released');
      syncLeftStickyState();
    };

    syncTitlePosition();
    syncLeftFooterSpace();
    syncLeftStickyRelease();
    syncLeftStickyState();
    window.addEventListener('load', syncTitlePosition, { once: true });
    window.addEventListener('load', syncLeftFooterSpace, { once: true });
    window.addEventListener('load', syncLeftStickyRelease, { once: true });
    window.addEventListener('load', syncLeftStickyState, { once: true });
    window.addEventListener('resize', syncTitlePosition);
    window.addEventListener('resize', syncLeftFooterSpace);
    window.addEventListener('resize', syncLeftStickyRelease);
    window.addEventListener('resize', syncLeftStickyState);
    let stickySyncFrame = null;
    const scheduleStickySync = () => {
      if (stickySyncFrame !== null) return;
      stickySyncFrame = requestAnimationFrame(() => {
        stickySyncFrame = null;
        syncLeftStickyRelease();
        syncLeftStickyState();
      });
    };
    window.addEventListener('scroll', scheduleStickySync, { passive: true });
    wrapper.querySelectorAll('.fd-media-card-' + sectionId + ' img').forEach(image => {
      if (image.complete) {
        syncTitlePosition();
        syncLeftStickyRelease();
        syncLeftStickyState();
      } else {
        image.addEventListener('load', syncTitlePosition, { once: true });
        image.addEventListener('load', syncLeftStickyRelease, { once: true });
        image.addEventListener('load', syncLeftStickyState, { once: true });
      }
    });

    const revealCards = wrapper.querySelectorAll('.fd-media-card-' + sectionId);
    const titleGroup = wrapper.querySelector('.fd-title-group-' + sectionId);
    const leftFooterReveal = wrapper.querySelector('.fd-left-footer-' + sectionId);
    const mobileTextReveals = wrapper.querySelectorAll('.fd-mobile-text-' + sectionId);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      if (titleGroup) titleGroup.classList.add('is-visible');
      if (leftFooterReveal) leftFooterReveal.classList.add('is-visible');
      mobileTextReveals.forEach(text => text.classList.add('is-visible'));
      revealCards.forEach(card => card.classList.add('is-visible'));
    } else if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          entry.target.classList.toggle('is-visible', entry.isIntersecting);
          if (entry.isIntersecting && entry.target.classList.contains('fd-media-card-' + sectionId)) {
            if (titleGroup) titleGroup.classList.add('is-visible');
            if (leftFooterReveal) leftFooterReveal.classList.add('is-visible');
          }
        });
      }, { rootMargin: '0px 0px -12% 0px', threshold: 0.18 });

      revealCards.forEach((card, index) => {
        card.style.transitionDelay = Math.min(index * 70, 280) + 'ms';
        revealObserver.observe(card);
      });
      if (titleGroup) {
        titleGroup.style.transitionDelay = '80ms';
        revealObserver.observe(titleGroup);
      }
      if (leftFooterReveal) {
        leftFooterReveal.style.transitionDelay = '180ms';
        revealObserver.observe(leftFooterReveal);
      }
      mobileTextReveals.forEach((text, index) => {
        text.style.transitionDelay = Math.min(index * 60, 180) + 'ms';
        revealObserver.observe(text);
      });
    } else {
      if (titleGroup) titleGroup.classList.add('is-visible');
      if (leftFooterReveal) leftFooterReveal.classList.add('is-visible');
      mobileTextReveals.forEach(text => text.classList.add('is-visible'));
      revealCards.forEach(card => card.classList.add('is-visible'));
    }

    const managedVideos = Array.from(wrapper.querySelectorAll('.fd-media-card-' + sectionId + ' video'));
    if (managedVideos.length) {
      const visibleVideos = new WeakSet();
      const syncManagedVideo = (video) => {
        if (!(video instanceof HTMLVideoElement)) return;
        if (document.hidden || !visibleVideos.has(video)) {
          video.pause();
          return;
        }
        const playPromise = video.play();
        if (playPromise && typeof playPromise.catch === 'function') {
          playPromise.catch(() => {});
        }
      };
      if ('IntersectionObserver' in window) {
        const videoObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target;
            if (entry.isIntersecting) {
              visibleVideos.add(video);
            } else {
              visibleVideos.delete(video);
            }
            syncManagedVideo(video);
          });
        }, { rootMargin: '120px 0px', threshold: 0.12 });
        managedVideos.forEach(video => videoObserver.observe(video));
      } else {
        managedVideos.forEach(video => visibleVideos.add(video));
      }
      document.addEventListener('visibilitychange', () => {
        managedVideos.forEach(syncManagedVideo);
      });
    }

    // 1. 左侧文本联动逻辑
    if (window.innerWidth >= 990) {
      const mediaItems = wrapper.querySelectorAll('.fd-media-item-' + sectionId);
      const titleItems = wrapper.querySelectorAll('.fd-project-title-item-' + sectionId);
      const footerItems = wrapper.querySelectorAll('.fd-project-footer-item-' + sectionId);
      const titleWrapper = wrapper.querySelector('.fd-project-title-wrapper-' + sectionId);

      const syncActiveTitleHeight = () => {
        if (!titleWrapper) return;

        const activeTitle = wrapper.querySelector('.fd-project-title-item-' + sectionId + '.is-active');
        if (!activeTitle) return;

        const height = Math.ceil(activeTitle.getBoundingClientRect().height);
        if (height > 0) {
          titleWrapper.style.setProperty('--active-title-height', height + 'px');
        }
      };

      syncActiveTitleHeight();
      window.addEventListener('resize', syncActiveTitleHeight);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(syncActiveTitleHeight);
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const activeIndex = entry.target.getAttribute('data-index');
            titleItems.forEach(text => { text.classList.toggle('is-active', text.getAttribute('data-index') === activeIndex); });
            footerItems.forEach(footer => { footer.classList.toggle('is-active', footer.getAttribute('data-index') === activeIndex); });
            wrapper.fdSyncHeatmapStyle?.();
            syncActiveTitleHeight();
          }
        });
      }, { rootMargin: '-50% 0px -50% 0px', threshold: 0 });

      mediaItems.forEach(item => observer.observe(item));
    }

  }

  document.addEventListener('DOMContentLoaded', initFDWorks);
  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') initFDWorks();
    });
  }
</script>

