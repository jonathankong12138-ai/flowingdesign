{% comment %}
  Section: Our Work (Koto 高级滚动悬停版)
{% endcomment %}

{%- style -%}
  .koto-section-{{ section.id }} {
    background-color: #ffffff; /* 背景色 */
    color: #000000;
    padding-top: 40px;
    padding-bottom: 80px;
  }

  /* --- 电脑端布局 (左右分屏) --- */
  @media screen and (min-width: 900px) {
    .koto-container-{{ section.id }} {
      display: flex;
      align-items: flex-start;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 5%;
    }

    /* 左侧文字区：固定在屏幕上 */
    .koto-left-panel {
      width: 40%;
      position: sticky;
      top: 15vh; /* 距离顶部的悬停位置 */
      height: 70vh; /* 留出上下空间 */
      display: flex;
      flex-direction: column;
      padding-right: 60px;
    }

    /* 右侧媒体区：正常滚动 */
    .koto-right-panel {
      width: 60%;
    }

    /* 包含所有文字块的容器 */
    .koto-text-wrapper {
      position: relative;
      flex-grow: 1;
      margin-top: 40px;
    }

    /* 每一个动态文字块（绝对定位，堆叠在一起） */
    .koto-text-item {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease, transform 0.5s ease;
      pointer-events: none; /* 隐藏时不可点击 */
    }

    /* 激活状态的文字块 */
    .koto-text-item.active {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* 手机端专用的文字块（在电脑端隐藏） */
    .koto-mobile-text {
      display: none;
    }
  }

  /* --- 手机端布局 (上下排列) --- */
  @media screen and (max-width: 899px) {
    .koto-container-{{ section.id }} {
      padding: 0 20px;
    }
    
    .koto-left-panel {
      margin-bottom: 30px;
    }

    /* 手机端隐藏左侧的动态文字块 */
    .koto-text-wrapper {
      display: none; 
    }

    /* 手机端显示跟在图片后面的文字块 */
    .koto-mobile-text {
      display: block;
      margin-top: 20px;
      margin-bottom: 60px;
    }
  }

  /* --- 通用样式 --- */
  .koto-main-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.1;
  }

  .koto-project-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    margin: 0 0 15px 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .koto-project-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #444;
    margin-bottom: 30px;
    max-width: 90%;
  }

  .koto-award-box {
    display: flex;
    align-items: center;
    gap: 15px;
    border-top: 1px solid #eee;
    padding-top: 20px;
  }

  .koto-award-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .koto-award-text {
    font-size: 0.9rem;
    color: #666;
    font-weight: 500;
  }

  .koto-media-item {
    margin-bottom: 100px; /* 两个作品之间的间距 */
    border-radius: 8px;
    overflow: hidden;
    background: #f4f4f4;
  }

  /* 最后一个作品不需要底边距 */
  .koto-media-item:last-child {
    margin-bottom: 0;
  }

  .koto-media-content {
    width: 100%;
    display: block;
  }

  .koto-media-content img, 
  .koto-media-content video {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
{%- endstyle -%}

<div id="koto-section-{{ section.id }}" class="koto-section-{{ section.id }}">
  <div class="koto-container-{{ section.id }}">
    
    <div class="koto-left-panel">
      <h2 class="koto-main-title">{{ section.settings.main_title }}</h2>
      
      <div class="koto-text-wrapper">
        {%- for block in section.blocks -%}
          <div class="koto-text-item {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <h3 class="koto-project-title">{{ block.settings.title }}</h3>
            <div class="koto-project-desc">{{ block.settings.description }}</div>
            
            {%- if block.settings.award_image != blank or block.settings.award_text != blank -%}
              <div class="koto-award-box">
                {%- if block.settings.award_image != blank -%}
                  <img src="{{ block.settings.award_image | image_url: width: 100 }}" class="koto-award-img" alt="Award">
                {%- endif -%}
                {%- if block.settings.award_text != blank -%}
                  <span class="koto-award-text">{{ block.settings.award_text }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="koto-right-panel">
      {%- for block in section.blocks -%}
        <div class="koto-media-item" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          
          <a href="{{ block.settings.link | default: '#' }}" class="koto-media-content">
            {%- if block.settings.video_url != blank -%}
              <video autoplay loop muted playsinline>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>

          <div class="koto-mobile-text">
            <h3 class="koto-project-title" style="font-size: 2rem;">{{ block.settings.title }}</h3>
            <div class="koto-project-desc">{{ block.settings.description }}</div>
            {%- if block.settings.award_image != blank or block.settings.award_text != blank -%}
              <div class="koto-award-box">
                {%- if block.settings.award_image != blank -%}
                  <img src="{{ block.settings.award_image | image_url: width: 100 }}" class="koto-award-img">
                {%- endif -%}
                <span class="koto-award-text">{{ block.settings.award_text }}</span>
              </div>
            {%- endif -%}
          </div>
          
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 只在电脑端运行滚动监听，以节省性能
    if (window.innerWidth < 900) return;

    const sectionId = 'koto-section-{{ section.id }}';
    const section = document.getElementById(sectionId);
    if (!section) return;

    const mediaItems = section.querySelectorAll('.koto-media-item');
    const textItems = section.querySelectorAll('.koto-text-item');

    // Intersection Observer 设置
    const observerOptions = {
      root: null,
      // 当图片的中线穿过屏幕垂直中心时触发切换
      rootMargin: '-50% 0px -50% 0px', 
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const activeIndex = entry.target.getAttribute('data-index');

          // 切换左侧文字的 active 状态
          textItems.forEach(text => {
            if (text.getAttribute('data-index') === activeIndex) {
              text.classList.add('active');
            } else {
              text.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    // 观察每一个右侧的图片/视频
    mediaItems.forEach(item => observer.observe(item));
  });
</script>

{% schema %}
{
  "name": "Koto 滚动悬停作品展示",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "左上角板块大标题",
      "default": "Our Work."
    }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "作品项目",
      "settings": [
        {
          "type": "header",
          "content": "媒体设置 (右侧)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "作品图片"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "或输入 MP4 视频链接",
          "info": "如果输入视频链接，将优先播放视频。请上传到 Shopify 后台文件(Files)中，并复制链接粘贴到这里。"
        },
        {
          "type": "url",
          "id": "link",
          "label": "点击跳转链接"
        },
        {
          "type": "header",
          "content": "文字设置 (左侧)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "作品大标题",
          "default": "项目名称"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "作品解说",
          "default": "<p>这里输入关于该作品的详细介绍，描述你们做了什么，达成了什么效果。</p>"
        },
        {
          "type": "header",
          "content": "奖项/提示设置"
        },
        {
          "type": "image_picker",
          "id": "award_image",
          "label": "奖项小 Logo"
        },
        {
          "type": "text",
          "id": "award_text",
          "label": "奖项小字提示",
          "default": "2026 最佳设计奖"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koto 滚动悬停作品展示",
      "blocks": [
        { "type": "project" },
        { "type": "project" },
        { "type": "project" }
      ]
    }
  ]
}
{% endschema %}