{% doc %}
  Renders the GTM design workflow methodology article for the Flowin Design method library.
{% enddoc %}

<div class="flowin-gtm-article">
  <header class="flowin-gtm-hero">
    <div class="flowin-gtm-kicker">
      <span>Method 01</span>
      <span>Go To Market</span>
      <span>OpenFit Series</span>
    </div>
    <div class="flowin-gtm-hero-grid">
      <div class="flowin-gtm-hero-copy">
        <h2>GTM<br>设计工作流</h2>
        <p>从产品价值包装、营销协同到上市交付，设计如何成为连接产品、用户与市场的核心支持角色。</p>
      </div>
      <div class="flowin-gtm-orbit" aria-hidden="true">
        <span class="flowin-gtm-orbit-label flowin-gtm-orbit-label--one">IPMS</span>
        <strong>GTM</strong>
        <span class="flowin-gtm-orbit-label flowin-gtm-orbit-label--two">Launch</span>
      </div>
    </div>
    <dl class="flowin-gtm-meta">
      <div><dt>产品矩阵</dt><dd>OpenFit / Air / 2</dd></div>
      <div><dt>设计角色</dt><dd>Design Representative</dd></div>
      <div><dt>工作阶段</dt><dd>6 Phases</dd></div>
    </dl>
  </header>

  <section class="flowin-gtm-section flowin-gtm-intro">
    <div class="flowin-gtm-section-index">01 / Context</div>
    <div class="flowin-gtm-section-body">
      <h3>从内部协作<br>走向外部战役</h3>
      <p class="flowin-gtm-lede">OpenFit 系列是 Shokz 的第二增长曲线。随着耳挂耳机市场扩张、消费者认知提升，OpenFit、OpenFit Air 与 OpenFit 2 逐步组成开耳系列的产品矩阵核心。</p>
      <p>当竞争加剧，营销团队需要从内部资源协调转向面向市场的整体战役。IPMS 与 GTM 因此被引入，用一套跨职能机制连接产品价值、营销传播与销售落地。</p>
      <div class="flowin-gtm-context-strip">
        <span>市场容量增长</span>
        <span>消费者认知提升</span>
        <span>竞争进入协同阶段</span>
      </div>
    </div>
  </section>

  <section class="flowin-gtm-section flowin-gtm-definitions">
    <div class="flowin-gtm-section-index">02 / Definition</div>
    <div class="flowin-gtm-section-body">
      <h3>从设计视角理解<br>IPMS 与 GTM</h3>
      <div class="flowin-gtm-definition-grid">
        <article>
          <div class="flowin-gtm-definition-code">IPMS</div>
          <h4>Integrated Product<br>Marketing &amp; Sales</h4>
          <p>负责产品价值包装，让产品能力被组织成清晰、可传播、可销售的价值表达。</p>
          <span>Product value proposition</span>
        </article>
        <article class="flowin-gtm-definition-card--dark">
          <div class="flowin-gtm-definition-code">GTM</div>
          <h4>Go To<br>Market</h4>
          <p>负责营销全面协同，让产品、设计、传播、销售与交付围绕同一上市目标运行。</p>
          <span>Cross-functional launch</span>
        </article>
      </div>
    </div>
  </section>

  <section class="flowin-gtm-section flowin-gtm-team">
    <div class="flowin-gtm-section-index">03 / Team</div>
    <div class="flowin-gtm-section-body">
      <h3>设计代表是产品价值<br>转译的核心节点</h3>
      <p class="flowin-gtm-lede">产品 GTM 团队由产品经理、设计代表、营销 GTM、物流、认证、法务与项目角色共同组成。设计不只是素材执行者，而是把卖点转化为买点、输出营销策略与工具包的支持代表。</p>
      <div class="flowin-gtm-team-map" aria-label="GTM 团队角色">
        <span>产品经理</span>
        <span class="is-core">设计代表</span>
        <span>营销 GTM</span>
        <span>物流</span>
        <span>认证</span>
        <span>法务</span>
        <span>项目</span>
      </div>
      <div class="flowin-gtm-responsibility-grid">
        <article><span>01</span><h4>管预算</h4><p>在上市节奏与资源约束之间，制定可执行的素材投入与制作计划。</p></article>
        <article><span>02</span><h4>管素材</h4><p>建立基础素材清单、渠道需求矩阵与交付标准，保证内容可复用。</p></article>
        <article><span>03</span><h4>管审美</h4><p>把产品卖点与营销概念转化为有辨识度、有格调的视觉表达。</p></article>
      </div>
    </div>
  </section>

  <section class="flowin-gtm-section flowin-gtm-process">
    <div class="flowin-gtm-section-index">04 / Workflow</div>
    <div class="flowin-gtm-section-body">
      <div class="flowin-gtm-process-heading">
        <h3>六大阶段</h3>
        <p>从商业逻辑与用户洞察开始，经由内容策划、素材执行和上市延展，最终进入交付复盘与生命周期闭环。</p>
      </div>
      <ol class="flowin-gtm-phase-list">
        <li>
          <div class="flowin-gtm-phase-head"><span>01</span><h4>立项与规划</h4></div>
          <dl><div><dt>输入</dt><dd>商业逻辑、用户洞察、卖点排序；用户反馈、商业竞品；生产时间计划</dd></div><div><dt>输出</dt><dd>设计立项、桌面调研、访谈研讨、设计项目计划</dd></div></dl>
          <figure class="flowin-gtm-phase-media">
            <img src="{{ 'fd-flowin-gtm-planning.webp' | asset_url }}" width="2190" height="1368" loading="lazy" alt="立项与规划阶段：组建设计小组、调研研讨与设计项目计划">
          </figure>
        </li>
        <li>
          <div class="flowin-gtm-phase-head"><span>02</span><h4>基础内容策划</h4></div>
          <dl><div><dt>输入</dt><dd>产品用户测试结论、FABE、Message House</dd></div><div><dt>输出</dt><dd>跨部门视觉研讨、视觉定调书、基础素材清单</dd></div></dl>
          <figure class="flowin-gtm-phase-media">
            <img src="{{ 'fd-flowin-gtm-content-planning.webp' | asset_url }}" width="2190" height="1368" loading="lazy" alt="基础内容策划阶段：跨部门视觉研讨、视觉定调书与基础素材清单">
          </figure>
        </li>
        <li>
          <div class="flowin-gtm-phase-head"><span>03</span><h4>产品素材执行</h4></div>
          <dl><div><dt>输入</dt><dd>产品 ID、样品；面向消费者的 Copy 文档</dd></div><div><dt>输出</dt><dd>Meet &amp; Spec、线下折页、产品页面、红人及官网礼盒、素材 Deck</dd></div></dl>
          <figure class="flowin-gtm-phase-media">
            <img src="{{ 'fd-flowin-gtm-product-assets.webp' | asset_url }}" width="2190" height="1368" loading="lazy" alt="产品素材执行阶段：Meet and Spec、产品页面、礼盒与素材 Deck">
          </figure>
        </li>
        <li>
          <div class="flowin-gtm-phase-head"><span>04</span><h4>上市延展阶段</h4></div>
          <dl><div><dt>输入</dt><dd>Integrated Marketing Communications 整合营销传播计划；市场用户测试结论</dd></div><div><dt>输出</dt><dd>核心卖点延展创意、地区定制素材包</dd></div></dl>
          <div class="flowin-gtm-video-grid" aria-label="上市延展阶段视频">
            <div class="flowin-gtm-video-card"><span>Film 01</span><iframe src="https://www.youtube-nocookie.com/embed/jbw2_Z54J2k" title="上市延展阶段视频 1" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
            <div class="flowin-gtm-video-card"><span>Film 02</span><iframe src="https://www.youtube-nocookie.com/embed/MKhwJH3P3rw" title="上市延展阶段视频 2" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
            <div class="flowin-gtm-video-card"><span>Film 03</span><iframe src="https://www.youtube-nocookie.com/embed/HMWk7dxGCbk" title="上市延展阶段视频 3" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
            <div class="flowin-gtm-video-card"><span>Film 04</span><iframe src="https://www.youtube-nocookie.com/embed/SHYrzdRUSUY" title="上市延展阶段视频 4" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
            <div class="flowin-gtm-video-card"><span>Film 05</span><iframe src="https://www.youtube-nocookie.com/embed/zWsnvjhQQxg" title="上市延展阶段视频 5" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
            <div class="flowin-gtm-video-card"><span>Film 06</span><iframe src="https://www.youtube-nocookie.com/embed/UFXiU2UD3Ew" title="上市延展阶段视频 6" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
          </div>
        </li>
        <li>
          <div class="flowin-gtm-phase-head"><span>05</span><h4>物料设计交付</h4></div>
          <dl><div><dt>输入</dt><dd>物料需求表、业务板块上市计划；第一周、首月、季度与半年的上市反馈</dd></div><div><dt>输出</dt><dd>上市物料设计、设计调整计划、设计复盘文档</dd></div></dl>
          <figure class="flowin-gtm-phase-media">
            <img src="{{ 'fd-flowin-gtm-delivery.webp' | asset_url }}" width="2190" height="1368" loading="lazy" alt="物料设计交付阶段：多地区与多渠道的上市传播物料">
          </figure>
        </li>
        <li>
          <div class="flowin-gtm-phase-head"><span>06</span><h4>复盘与生命周期</h4></div>
          <dl><div><dt>输入</dt><dd>阶段性上市反馈与产品生命周期计划</dd></div><div><dt>输出</dt><dd>设计调整计划、设计复盘文档，并持续进入下一轮闭环</dd></div></dl>
        </li>
      </ol>
    </div>
  </section>

  <section class="flowin-gtm-product-case">
    <div class="flowin-gtm-case-label">Case / OpenFit 2 Product Page</div>
    <div class="flowin-gtm-case-head">
      <h3>产品页是整条 GTM 链路<br>最核心的决策落点</h3>
      <p>它承接全部产品信息，也是消费者完成理解与购买判断的关键阵地。页面的功能由官网团队主责，内容定义则来自 GTM 团队。</p>
    </div>
    <div class="flowin-gtm-decision-grid">
      <article><span>FABE</span><h4>决定卖点顺序</h4><p>超大发声单元必须靠前，让核心价值在浏览路径早期被感知。</p></article>
      <article><span>Copy</span><h4>决定用户看到什么</h4><p>尺寸信息需要被放大，让技术规格快速转译为可理解的产品优势。</p></article>
      <article><span>Visual Direction</span><h4>决定如何被看见</h4><p>使用裸露元器件、大透视与高对比，建立高端科技感和差异化表达。</p></article>
    </div>
    <blockquote>功能回答“用户如何看、如何买、如何迭代”；内容回答“卖点以什么顺序、什么语言、什么视觉被理解”。</blockquote>
  </section>

  <section class="flowin-gtm-section flowin-gtm-challenges">
    <div class="flowin-gtm-section-index">05 / Friction</div>
    <div class="flowin-gtm-section-body">
      <h3>关键难点</h3>
      <div class="flowin-gtm-challenge-grid">
        <article><span>01</span><h4>产销互锁难</h4><p>生产和营销节点原则上强绑定，但生产材料不稳定等变量会使营销节点延后甚至取消。</p></article>
        <article><span>02</span><h4>评审难固化</h4><p>相关方过多且产销节奏难以互锁，团队经常面临“到货即发货”的压缩评审处境。</p></article>
        <article><span>03</span><h4>用研验证久</h4><p>用户研究资源稀缺，营销策略难以及时获得验证，设计需要预留持续调整与复盘机制。</p></article>
      </div>
    </div>
  </section>

  <section class="flowin-gtm-conclusion" aria-label="设计结论">
    <span>Design takeaway</span>
    <p>GTM 设计的价值，不只在于完成一组上市物料，而在于让产品价值、用户理解、营销协同与交付节奏形成可以持续复用的系统。</p>
  </section>
</div>

{% stylesheet %}
  .flowin-gtm-article {
    --gtm-paper: #f3f1eb;
    --gtm-ink: #111111;
    --gtm-muted: rgba(17, 17, 17, 0.58);
    --gtm-line: rgba(17, 17, 17, 0.14);
    --gtm-accent: #4858ff;
    color: var(--gtm-ink);
    background: var(--gtm-paper);
    font-family: "Noto Sans SC", "Urbanist", sans-serif;
  }

  .flowin-gtm-article *,
  .flowin-gtm-article *::before,
  .flowin-gtm-article *::after {
    box-sizing: border-box;
  }

  .flowin-gtm-article h2,
  .flowin-gtm-article h3,
  .flowin-gtm-article h4,
  .flowin-gtm-article p,
  .flowin-gtm-article dl,
  .flowin-gtm-article dd,
  .flowin-gtm-article blockquote {
    margin: 0;
  }

  .flowin-gtm-hero {
    min-height: 780px;
    padding: 54px 64px 52px;
    display: grid;
    grid-template-rows: auto 1fr auto;
    border-bottom: 1px solid var(--gtm-line);
    overflow: hidden;
    position: relative;
  }

  .flowin-gtm-kicker {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--gtm-line);
    font-family: "Urbanist", sans-serif;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .flowin-gtm-kicker span:last-child {
    text-align: right;
  }

  .flowin-gtm-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);
    align-items: center;
    gap: 72px;
  }

  .flowin-gtm-hero-copy h2 {
    font-family: "Urbanist", "Noto Sans SC", sans-serif;
    font-size: clamp(92px, 7.2vw, 132px);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.065em;
  }

  .flowin-gtm-hero-copy p {
    max-width: 600px;
    margin-top: 42px;
    font-size: 21px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--gtm-muted);
  }

  .flowin-gtm-orbit {
    width: 430px;
    aspect-ratio: 1;
    justify-self: end;
    border-radius: 50%;
    position: relative;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 50% 50%, var(--gtm-paper) 0 30%, transparent 30.5%),
      conic-gradient(from 215deg, var(--gtm-accent), #91a0ff 30%, #ffb45e 62%, #ff5b35 82%, var(--gtm-accent));
    box-shadow: inset 0 0 0 1px rgba(17, 17, 17, 0.08);
  }

  .flowin-gtm-orbit::before,
  .flowin-gtm-orbit::after {
    content: "";
    position: absolute;
    border: 1px solid rgba(17, 17, 17, 0.22);
    border-radius: 50%;
  }

  .flowin-gtm-orbit::before { inset: 14%; }
  .flowin-gtm-orbit::after { inset: 29%; }

  .flowin-gtm-orbit strong {
    font-family: "Urbanist", sans-serif;
    font-size: 68px;
    font-weight: 500;
    letter-spacing: -0.06em;
    position: relative;
    z-index: 1;
  }

  .flowin-gtm-orbit-label {
    position: absolute;
    padding: 8px 12px;
    border: 1px solid rgba(17, 17, 17, 0.18);
    border-radius: 999px;
    background: rgba(243, 241, 235, 0.88);
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    z-index: 2;
  }

  .flowin-gtm-orbit-label--one { left: 2%; top: 25%; }
  .flowin-gtm-orbit-label--two { right: 0; bottom: 22%; }

  .flowin-gtm-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 22px;
    border-top: 1px solid var(--gtm-line);
  }

  .flowin-gtm-meta div {
    display: flex;
    justify-content: space-between;
    gap: 24px;
  }

  .flowin-gtm-meta dt,
  .flowin-gtm-section-index,
  .flowin-gtm-case-label {
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gtm-muted);
  }

  .flowin-gtm-meta dd {
    font-family: "Urbanist", sans-serif;
    font-size: 14px;
    text-align: right;
  }

  .flowin-gtm-section {
    display: grid;
    grid-template-columns: 200px minmax(0, 1fr);
    gap: 72px;
    padding: 112px 64px;
    border-bottom: 1px solid var(--gtm-line);
  }

  .flowin-gtm-section-body > h3,
  .flowin-gtm-process-heading h3 {
    font-size: 58px;
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  .flowin-gtm-lede {
    max-width: 830px;
    margin-top: 56px !important;
    font-size: 25px;
    font-weight: 300;
    line-height: 1.65;
  }

  .flowin-gtm-section-body > p:not(.flowin-gtm-lede) {
    max-width: 760px;
    margin-top: 28px;
    font-size: 17px;
    line-height: 1.8;
    color: var(--gtm-muted);
  }

  .flowin-gtm-context-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 72px;
    border-top: 1px solid var(--gtm-line);
    border-bottom: 1px solid var(--gtm-line);
  }

  .flowin-gtm-context-strip span {
    min-height: 116px;
    padding: 24px;
    display: flex;
    align-items: flex-end;
    font-size: 15px;
    border-right: 1px solid var(--gtm-line);
  }

  .flowin-gtm-context-strip span:last-child { border-right: 0; }

  .flowin-gtm-definition-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-top: 64px;
  }

  .flowin-gtm-definition-grid article {
    min-height: 420px;
    padding: 34px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--gtm-line);
    border-radius: 6px;
  }

  .flowin-gtm-definition-card--dark {
    background: var(--gtm-ink);
    color: #ffffff;
  }

  .flowin-gtm-definition-code {
    font-family: "Urbanist", sans-serif;
    font-size: 72px;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .flowin-gtm-definition-grid h4 {
    margin-top: 72px !important;
    font-family: "Urbanist", sans-serif;
    font-size: 25px;
    font-weight: 500;
    line-height: 1.15;
  }

  .flowin-gtm-definition-grid p {
    max-width: 440px;
    margin-top: 22px !important;
    font-size: 16px;
    line-height: 1.7;
    color: var(--gtm-muted);
  }

  .flowin-gtm-definition-card--dark p { color: rgba(255, 255, 255, 0.64); }

  .flowin-gtm-definition-grid article > span:last-child {
    margin-top: auto;
    padding-top: 32px;
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.56;
  }

  .flowin-gtm-team-map {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    margin-top: 64px;
    position: relative;
  }

  .flowin-gtm-team-map::before {
    content: "";
    position: absolute;
    left: 4%;
    right: 4%;
    top: 50%;
    height: 1px;
    background: var(--gtm-line);
  }

  .flowin-gtm-team-map span {
    min-height: 92px;
    padding: 16px 10px;
    display: grid;
    place-items: center;
    border: 1px solid var(--gtm-line);
    border-radius: 50%;
    background: var(--gtm-paper);
    font-size: 13px;
    text-align: center;
    position: relative;
  }

  .flowin-gtm-team-map .is-core {
    background: var(--gtm-accent);
    border-color: var(--gtm-accent);
    color: #ffffff;
    transform: scale(1.08);
  }

  .flowin-gtm-responsibility-grid,
  .flowin-gtm-challenge-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 70px;
  }

  .flowin-gtm-responsibility-grid article,
  .flowin-gtm-challenge-grid article {
    min-height: 280px;
    padding: 28px;
    border-top: 1px solid var(--gtm-ink);
    background: rgba(255, 255, 255, 0.32);
  }

  .flowin-gtm-responsibility-grid span,
  .flowin-gtm-challenge-grid span {
    font-family: "Urbanist", sans-serif;
    font-size: 13px;
    color: var(--gtm-muted);
  }

  .flowin-gtm-responsibility-grid h4,
  .flowin-gtm-challenge-grid h4 {
    margin-top: 72px !important;
    font-size: 27px;
    font-weight: 400;
  }

  .flowin-gtm-responsibility-grid p,
  .flowin-gtm-challenge-grid p {
    margin-top: 18px !important;
    font-size: 15px;
    line-height: 1.75;
    color: var(--gtm-muted);
  }

  .flowin-gtm-process-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 430px;
    gap: 64px;
    align-items: end;
  }

  .flowin-gtm-process-heading p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--gtm-muted);
  }

  .flowin-gtm-phase-list {
    list-style: none;
    margin: 72px 0 0;
    padding: 0;
    border-top: 1px solid var(--gtm-ink);
  }

  .flowin-gtm-phase-list > li {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 48px;
    padding: 32px 0 36px;
    border-bottom: 1px solid var(--gtm-line);
  }

  .flowin-gtm-phase-head {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
  }

  .flowin-gtm-phase-head span {
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    color: var(--gtm-muted);
  }

  .flowin-gtm-phase-head h4 {
    font-size: 23px;
    font-weight: 400;
    line-height: 1.3;
  }

  .flowin-gtm-phase-list dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 40px;
  }

  .flowin-gtm-phase-list dl div {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 14px;
  }

  .flowin-gtm-phase-list dt {
    font-size: 12px;
    color: var(--gtm-muted);
  }

  .flowin-gtm-phase-list dd {
    font-size: 14px;
    line-height: 1.75;
  }

  .flowin-gtm-phase-media,
  .flowin-gtm-video-grid {
    display: none;
    grid-column: 1 / -1;
    margin: 22px 0 0;
  }

  .flowin-gtm-phase-media {
    overflow: hidden;
    background: #eceae5;
  }

  .flowin-gtm-phase-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .flowin-gtm-video-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .flowin-gtm-video-card {
    min-width: 0;
    padding: 10px;
    background: var(--gtm-ink);
  }

  .flowin-gtm-video-card span {
    display: block;
    padding: 2px 2px 10px;
    font-family: "Urbanist", sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .flowin-gtm-video-card iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: #000000;
  }

  .flowin-gtm-product-case {
    margin: 0;
    padding: 72px 64px 88px;
    background: var(--gtm-ink);
    color: #ffffff;
  }

  .flowin-gtm-product-case .flowin-gtm-case-label { color: rgba(255, 255, 255, 0.5); }

  .flowin-gtm-case-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 440px;
    gap: 80px;
    align-items: end;
    margin-top: 86px;
  }

  .flowin-gtm-case-head h3 {
    font-size: 58px;
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  .flowin-gtm-case-head p {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.62);
  }

  .flowin-gtm-decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 84px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .flowin-gtm-decision-grid article {
    min-height: 310px;
    padding: 28px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .flowin-gtm-decision-grid article:last-child { border-right: 0; }

  .flowin-gtm-decision-grid span {
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ba5ff;
  }

  .flowin-gtm-decision-grid h4 {
    margin-top: 96px !important;
    font-size: 25px;
    font-weight: 400;
  }

  .flowin-gtm-decision-grid p {
    margin-top: 18px !important;
    font-size: 14px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.58);
  }

  .flowin-gtm-product-case blockquote {
    max-width: 1020px;
    padding: 78px 0 10px;
    font-size: 33px;
    font-weight: 300;
    line-height: 1.55;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.88);
  }

  .flowin-gtm-challenge-grid article { min-height: 320px; }

  .flowin-gtm-conclusion {
    min-height: 520px;
    padding: 72px 64px;
    display: grid;
    grid-template-columns: 200px minmax(0, 1fr);
    gap: 72px;
    align-items: start;
    background: var(--gtm-accent);
    color: #ffffff;
  }

  .flowin-gtm-conclusion span {
    font-family: "Urbanist", sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .flowin-gtm-conclusion p {
    max-width: 990px;
    font-size: 48px;
    font-weight: 300;
    line-height: 1.35;
    letter-spacing: -0.035em;
  }

  @media (max-width: 1100px) {
    .flowin-gtm-hero-grid { grid-template-columns: 1fr 320px; gap: 40px; }
    .flowin-gtm-orbit { width: 320px; }
    .flowin-gtm-orbit strong { font-size: 50px; }
    .flowin-gtm-section { grid-template-columns: 150px minmax(0, 1fr); gap: 42px; }
    .flowin-gtm-team-map { grid-template-columns: repeat(4, 1fr); }
    .flowin-gtm-team-map::before { display: none; }
    .flowin-gtm-team-map span { border-radius: 999px; min-height: 64px; }
    .flowin-gtm-process-heading,
    .flowin-gtm-case-head { grid-template-columns: 1fr; }
    .flowin-gtm-video-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 768px) {
    .flowin-gtm-phase-media { display: block; }
    .flowin-gtm-video-grid { display: grid; }
  }

  @media (max-width: 767px) {
    .flowin-gtm-hero { min-height: auto; padding: 28px 20px 34px; }
    .flowin-gtm-kicker { grid-template-columns: 1fr auto; }
    .flowin-gtm-kicker span:nth-child(2) { display: none; }
    .flowin-gtm-hero-grid { grid-template-columns: 1fr; padding: 72px 0 52px; }
    .flowin-gtm-hero-copy h2 { font-size: 64px; }
    .flowin-gtm-hero-copy p { margin-top: 28px; font-size: 17px; }
    .flowin-gtm-orbit { width: min(78vw, 300px); justify-self: center; }
    .flowin-gtm-meta { grid-template-columns: 1fr; gap: 12px; }
    .flowin-gtm-section { grid-template-columns: 1fr; gap: 34px; padding: 72px 20px; }
    .flowin-gtm-section-body > h3,
    .flowin-gtm-process-heading h3,
    .flowin-gtm-case-head h3 { font-size: 39px; }
    .flowin-gtm-lede { margin-top: 38px !important; font-size: 20px; }
    .flowin-gtm-context-strip,
    .flowin-gtm-definition-grid,
    .flowin-gtm-responsibility-grid,
    .flowin-gtm-challenge-grid,
    .flowin-gtm-decision-grid { grid-template-columns: 1fr; }
    .flowin-gtm-context-strip span,
    .flowin-gtm-decision-grid article { border-right: 0; border-bottom: 1px solid var(--gtm-line); }
    .flowin-gtm-team-map { grid-template-columns: repeat(2, 1fr); }
    .flowin-gtm-phase-list > li,
    .flowin-gtm-phase-list dl { grid-template-columns: 1fr; }
    .flowin-gtm-product-case { padding: 52px 20px 72px; }
    .flowin-gtm-case-head { margin-top: 52px; gap: 30px; }
    .flowin-gtm-product-case blockquote { padding-top: 58px; font-size: 25px; }
    .flowin-gtm-conclusion { min-height: 420px; grid-template-columns: 1fr; gap: 64px; padding: 52px 20px; }
    .flowin-gtm-conclusion p { font-size: 33px; }
  }
{% endstylesheet %}
